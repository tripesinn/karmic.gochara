# ── Flask / App ─────────────────────────────────────────────────────────────
SECRET_KEY=gochara-secret-2024                  # Change in production!
JWT_SECRET=change-me-to-a-random-secret          # JWT signing key
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARNING | ERROR

# ── Stripe ───────────────────────────────────────────────────────────────────
KARMIC_STRIPE_SECRET_KEY=sk_live_...
KARMIC_STRIPE_WEBHOOK_SECRET=whsec_...

# Produits (créer via Stripe Dashboard)
# "Karmic Gochara - Test Gemma"         → 4,99 € one-time
STRIPE_PRICE_TEST_GEMMA=price_...
STRIPE_PRODUCT_TEST_GEMMA=prod_...

# "Karmic Gochara - Chatbot Gemma Illimité" → 9,99 €/mois récurrent
STRIPE_PRICE_GEMMA_UNLIMITED=price_...
STRIPE_PRODUCT_GEMMA_UNLIMITED=prod_...

# ── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
SHEET_ID=1abc...
GOOGLE_SHEET_ID=1abc...                        # Alternative sheet ID

# ── AI Providers ─────────────────────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# xAI Grok (dynamic model routing)
GROK_API_KEY=xai-...
GROK_MODEL=auto                                # or specific: grok-4.3, etc.

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter (user-provided per profile, no server key needed)

# Gemma / Local AI
GEMMA_ENDPOINT=                                # Local Gemma endpoint URL
GEMMA_AUTH=                                    # Local Gemma auth token
GEMMA_MODEL=gemma-2-9b-it
GEMMA_MAX_TOKENS_HOOK=500
GEMMA_MAX_TOKENS_SYNTHESIS=2000
GEMMA_MAX_TOKENS_CALENDAR=800

# ── Model Selection (overrides per use case) ─────────────────────────────────
# Defaults shown — change to switch providers
HOOK_MODEL=grok-beta                           # Free hook model (grok-beta | gemini-2.5-flash | claude-sonnet-4-6)
SYNTHESIS_MODEL=claude-3-opus-latest           # Paid synthesis model

# ── Local AI / Feature Flags ─────────────────────────────────────────────────
ENABLE_LOCAL_AI=false                          # Set to '1' or 'true' to enable
ENABLE_FEATURES=false

# ── Vault / Doctrine ─────────────────────────────────────────────────────────
VAULT_PATH=karmic_vault/
RETRY_LIMIT=3
ORB_HOOK=1.0
ORB_SYNTHESIS=3.0

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cron / Automation ────────────────────────────────────────────────────────
CRON_SECRET=                                   # Secret token for cron endpoints

# ── X.com Bot ────────────────────────────────────────────────────────────────
XAI_API_KEY=                                   # xAI API key (alias for GROK_API_KEY)
X_API_KEY=                                     # X.com API key
X_API_SECRET=                                  # X.com API secret
X_ACCESS_TOKEN=                                # X.com access token
X_ACCESS_TOKEN_SECRET=                         # X.com access token secret

# ── Payments / Links ─────────────────────────────────────────────────────────
MYPOS_URL=https://mypos.com/@karmic-gochara
DEEP_LINK_BASE_URL=                            # Override for deep links (default: request.host_url)
