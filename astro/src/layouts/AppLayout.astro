---
// src/layouts/AppLayout.astro — Layout protégé pour zone connectée
// Vérifie l'auth client-side via /api/profile
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Espace Karmic Gochara', ogImage } = Astro.props;
---

<meta name="title" content={title} />
<meta name="description" content={description} />

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "WebSite",
  "name": "{title}",
  "url": "https://yourdomain.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://yourdomain.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="min-h-screen flex flex-col">
    <!-- Top bar -->
    <header
      class="sticky top-0 z-40 border-b border-cosmic-border/50 bg-cosmic-bg/90 backdrop-blur-md"
    >
      <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/app/index.html" class="font-display text-cosmic-gold text-lg tracking-wider hover:text-cosmic-gold/80 transition">
          ✦ Karmic Gochara
        </a>

        <div class="flex items-center gap-4 text-sm">
          <a href="/app/index.html" class="text-cosmic-text-dim hover:text-cosmic-gold transition" data-i18n="nav.dashboard">
            Accueil
          </a>
          <a href="/app/lecture/index.html" class="text-cosmic-text-dim hover:text-cosmic-gold transition" data-i18n="nav.reading">
            Gochara
          </a>
          <a href="/app/miroir/index.html" class="text-cosmic-text-dim hover:text-cosmic-gold transition" data-i18n="nav.chart">
            Carte Astrale
          </a>
          <a href="/app/chat/index.html" class="text-cosmic-text-dim hover:text-cosmic-gold transition" data-i18n="nav.chat">
            Chat
          </a>
          <button
            id="logout-btn"
            class="text-cosmic-text-dim/60 hover:text-red-400 transition text-xs ml-2"
            data-i18n="settings.logout"
          >
            Quitter
          </button>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-cosmic-border/30 py-6 text-center text-cosmic-text-dim/40 text-xs">
      <p>Karmic Gochara &mdash; L&rsquo;alchimie des cycles cosmiques</p>
    </footer>
  </div>

  <script>
    import { api } from '../lib/api';
    import { auth } from '../lib/firebase';
    import { onAuthStateChanged, signOut } from '@firebase/auth';
    import { initRevenueCat } from '../lib/revenuecat';
    import { i18n } from '../lib/i18n';

    // Initialisation i18n client-side
    i18n.apply();

    // Ré-appliquer si changement
    window.addEventListener('karmic-lang-changed', () => {
      i18n.apply();
    });

    // Vérification auth côté client
    (async () => {
      const finalLang = i18n.detect();
      try {
        await api.setLang(finalLang);
      } catch (e) {}

      console.log('📡 [AUTH] Initialisation Layout protégé...');

      // On attend que Firebase s'initialise (max 3s)
      const getUser = () => new Promise((resolve) => {
        const unsubscribe = onAuthStateChanged(auth, (user) => {
          unsubscribe();
          resolve(user);
        });
        setTimeout(() => resolve(auth.currentUser), 3000);
      });

      try {
        let user = await getUser();

        if (!user) {
          console.warn('📡 [AUTH] Session Firebase absente après attente, redirection');
          localStorage.removeItem('karmic_token');
          window.location.replace('/');
          return;
        }

        console.log('✅ [AUTH] Session active:', user.email);

        // Vérification session backend
        let resp = await api.profile().catch(() => ({ ok: false }));

        if (!resp.ok) {
          console.warn('🔄 [AUTH] Session backend invalide, tentative de restauration...');
          const idToken = await user.getIdToken(true);
          const loginResp = await api.loginFirebase(user.email || '', idToken);
          if (loginResp.ok) {
            resp = await api.profile();
          }
        }

        if (resp.ok) {
          console.log('🎊 [AUTH] Authentification complète OK');
          const el = document.getElementById('welcome-pseudo');
          if (el && resp.profile?.pseudo) {
            el.textContent = `${i18n.t('welcome.subtitle')} ${resp.profile.pseudo}`;
          }
          
          if (resp.profile?.pseudo) {
            await initRevenueCat(resp.profile.pseudo);
          }
        } else {
          console.warn('📡 [AUTH] Impossible de valider la session backend');
          window.location.replace('/');
        }
      } catch (err) {
        console.warn('📡 [AUTH] Erreur durant la vérification:', err);
        window.location.replace('/');
      }
    })();

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      try {
        await api.logout();
        await signOut(auth);
        localStorage.removeItem('karmic_token');
      } catch (e) {
        console.error('Logout error:', e);
      }
      window.location.href = '/';
    });
  </script>
</BaseLayout>
