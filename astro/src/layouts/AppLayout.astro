---
// src/layouts/AppLayout.astro — Layout protégé pour zone connectée
// Vérifie l'auth client-side via /api/profile
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Espace Karmic Gochara', ogImage } = Astro.props;
---

<meta name="title" content={title} />
<meta name="description" content={description} />

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "WebSite",
  "name": "{title}",
  "url": "https://yourdomain.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://yourdomain.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="min-h-screen flex flex-col">
    <!-- Top bar -->
    <header
      class="sticky top-0 z-40 border-b border-cosmic-border/50 bg-cosmic-bg/90 backdrop-blur-md"
    >
      <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/app" class="font-display text-cosmic-gold text-lg tracking-wider hover:text-cosmic-gold/80 transition">
          ✦ Karmic Gochara
        </a>

        <div class="flex items-center gap-4 text-sm">
          <a href="/app" class="text-cosmic-text-dim hover:text-cosmic-gold transition">
            Tableau
          </a>
          <a href="/app/lecture" class="text-cosmic-text-dim hover:text-cosmic-gold transition">
            Lecture
          </a>
          <a href="/app/profil" class="text-cosmic-text-dim hover:text-cosmic-gold transition">
            Profil
          </a>
          <button
            id="logout-btn"
            class="text-cosmic-text-dim/60 hover:text-red-400 transition text-xs ml-2"
          >
            Quitter
          </button>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-cosmic-border/30 py-6 text-center text-cosmic-text-dim/40 text-xs">
      <p>Karmic Gochara &mdash; L&rsquo;alchimie des cycles cosmiques</p>
    </footer>
  </div>

  <script>
    import { api } from '../lib/api';

    // Vérification auth côté client
    (async () => {
      // Détection de la langue du navigateur
      const browserLang = navigator.language.split('-')[0];
      const supportedLangs = ['fr', 'en', 'es', 'pt', 'de', 'nl', 'it'];
      const finalLang = supportedLangs.includes(browserLang) ? browserLang : 'fr';

      try {
        await api.setLang(finalLang);
        console.log(`🌐 [I18N] Langue définie sur : ${finalLang}`);
      } catch (e) {
        console.warn('⚠️ [I18N] Échec de la définition de la langue');
      }

      console.log('📡 [AUTH] Vérification du profil...');
      try {
        const resp = await api.profile();
        if (!resp.ok) {
          console.warn('❌ [AUTH] Profil invalide ou inexistant:', resp);
          if ((resp as any).needs_register) {
            window.location.href = '/register/';
          } else {
            window.location.href = '/';
          }
        } else {
          console.log('✅ [AUTH] Profil chargé pour:', resp.profile?.pseudo);
        }
      } catch (err) {
        console.error('❌ [AUTH] Échec de la vérification du profil:', err);
        // On ne redirige pas immédiatement en cas de timeout pour éviter la boucle
        // sauf si l'erreur est explicite
        if (err instanceof Error && err.message.includes('401')) {
           window.location.href = '/';
        }
      }
    })();

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      try { await api.logout(); } catch {}
      window.location.href = '/';
    });
  </script>
</BaseLayout>
