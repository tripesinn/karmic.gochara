---
// src/pages/app/carte.astro
import AppLayout from '../../layouts/AppLayout.astro';
import KarmicChart from '../../components/KarmicChart.astro';
---

<AppLayout title="Carte Astrale — Karmic Gochara">
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-12">
    <section class="text-center animate-fade-in">
      <h1 class="text-4xl sm:text-5xl font-display text-cosmic-gold mb-3">✦ Carte Astrale</h1>
      <p class="text-cosmic-text-dim text-lg">Explore tes transits planétaires et ta configuration natale.</p>
    </section>

    <div id="carte-loading" class="text-center text-cosmic-text-dim">Connexion aux astres...</div>
    
    <section id="carte-content" class="hidden justify-center">
      <KarmicChart />
    </section>
  </div>

  <script>
    import { api } from '../../lib/api';

    async function checkAccess() {
      try {
        const resp = await api.profile();
        const loading = document.getElementById('carte-loading');
        const contentSection = document.getElementById('carte-content');

        if (loading) loading.style.display = 'none';

        if (resp.ok && resp.profile) {
          if (contentSection) {
            contentSection.classList.remove('hidden');
          }
        }
      } catch (e) {
        console.error("Erreur checkAccess Carte Astrale:", e);
      }
    }

    checkAccess();
  </script>
</AppLayout>
