---
// src/pages/app/carte.astro
import AppLayout from '../../layouts/AppLayout.astro';
import KarmicChart from '../../components/KarmicChart.astro';
---

<AppLayout title="Carte Astrale — Karmic Gochara">
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-12">
    <section class="text-center animate-fade-in">
      <h1 class="text-4xl sm:text-5xl font-display text-cosmic-gold mb-3">✦ Carte Astrale</h1>
      <p class="text-cosmic-text-dim text-lg">Explore tes transits planétaires et ta configuration natale.</p>
    </section>

    <div id="carte-loading" class="text-center text-cosmic-text-dim">Connexion aux astres...</div>
    
    <section id="carte-content" class="hidden justify-center">
      <KarmicChart />
    </section>
  </div>

  <script>
    import { api } from '../../lib/api';

    async function checkAccess() {
      try {
        const resp = await api.profile();
        const loading = document.getElementById('carte-loading');
        const contentSection = document.getElementById('carte-content');

        if (loading) loading.style.display = 'none';

        if (resp.ok && resp.profile) {
          if (contentSection) {
            contentSection.classList.remove('hidden');
          }
          
          const p = resp.profile;
          
          // Hydratation Infos de Naissance
          if (p.day && p.month && p.year) {
             const birthDateStr = `${p.day.toString().padStart(2, '0')}/${p.month.toString().padStart(2, '0')}/${p.year}`;
             const el = document.getElementById('chart-date');
             if (el) el.textContent = birthDateStr;
          } else if (p.birth_date) {
             const el = document.getElementById('chart-date');
             if (el) el.textContent = p.birth_date;
          }

          if (p.hour !== undefined && p.minute !== undefined) {
             const birthTimeStr = `${p.hour.toString().padStart(2, '0')}h${p.minute.toString().padStart(2, '0')}`;
             const el = document.getElementById('chart-time');
             if (el) el.textContent = birthTimeStr;
          } else if (p.birth_time) {
             const el = document.getElementById('chart-time');
             if (el) el.textContent = p.birth_time;
          }

          if (p.city || p.birth_location) {
             const el = document.getElementById('chart-location');
             if (el) el.textContent = p.city || p.birth_location;
          }

          // Fetch and inject actual SVG chart
          try {
             const svgText = await api.getChartSvg();
             const container = document.getElementById('chart-svg-container');
             if (container && svgText) {
                container.innerHTML = svgText;
             }
          } catch (e) {
             console.error("Erreur récupération SVG:", e);
          }

          // Hydratation Planètes
          const planets = p.planets_info || [];
          if (planets.length > 0) {
            const noPlanetsMsg = document.getElementById('chart-no-planets');
            if (noPlanetsMsg) noPlanetsMsg.style.display = 'none';
            
            const table = document.getElementById('chart-planets-table');
            if (table) table.classList.remove('hidden');
            
            const tbody = document.getElementById('chart-planets-body');
            if (tbody) {
              tbody.innerHTML = '';
              planets.forEach(pl => {
                const isRetro = pl.retrograde;
                const tr = document.createElement('tr');
                tr.className = 'border-b border-cosmic-border/50 last:border-b-0';
                tr.innerHTML = `
                  <td class="py-2 pr-3 text-cosmic-gold font-display text-sm">
                    ${isRetro ? '℞ ' : ''}${pl.name || 'Inconnu'}
                  </td>
                  <td class="py-2 pr-3 text-cosmic-text">${pl.sign || '-'}</td>
                  <td class="py-2 pr-3 text-cosmic-text">${pl.degree || 0}°</td>
                  <td class="py-2 pr-3 text-cosmic-text">${pl.house || '-'}</td>
                  <td class="py-2 text-cosmic-text-dim text-xs italic">
                    ${isRetro ? 'Retrograde' : 'Direct'}
                  </td>
                `;
                tbody.appendChild(tr);
              });
            }
          }
        }
      } catch (e) {
        console.error("Erreur checkAccess Carte Astrale:", e);
      }
    }

    checkAccess();
  </script>
</AppLayout>
