---
// src/pages/app/index.astro — Dashboard connecté
import AppLayout from '../../layouts/AppLayout.astro';
import type { User } from '../../lib/types';
import { api } from '../../lib/api';

// SSR check — Astro SSG n'a pas accès aux cookies côté serveur,
// la vérification réelle se fait côté client dans AppLayout.
// En SSG, on rend la page statique; l'auth check client-side
// redirige si non connecté.
---

<AppLayout title="Mon espace — Karmic Gochara">
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-12">
    <!-- Welcome -->
    <section class="text-center animate-fade-in">
      <h1 class="text-4xl sm:text-5xl font-display text-cosmic-gold mb-3">✦ Bon retour</h1>
      <p class="text-cosmic-text-dim text-lg" id="welcome-pseudo">Bienvenue dans ton espace</p>
      <p class="text-cosmic-text-dim text-sm mt-2">
        <a href="/register" class="text-cosmic-gold hover:underline font-medium">✦ Compléter mon profil karmique →</a>
      </p>
    </section>

    <!-- Quick actions -->
    <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a
        href="/app/lecture"
        class="group p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center"
      >
        <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-500">🌟</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1">Lecture du Jour</h3>
        <p class="text-cosmic-text-dim text-sm">Reçois ton analyse karmique quotidienne</p>
      </a>

      <div
        class="p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center cursor-pointer"
      >
        <div class="text-3xl mb-3">📊</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1">Carte Astrale</h3>
        <p class="text-cosmic-text-dim text-sm">Explore tes transits planétaires</p>
      </div>

      <div
        class="p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center cursor-pointer"
      >
        <div class="text-3xl mb-3">💬</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1">Chat Karmique</h3>
        <p class="text-cosmic-text-dim text-sm">Pose tes questions à l&rsquo;IA</p>
      </div>
    </section>

    <!-- Recent readings placeholder -->
    <section class="border-t border-cosmic-border/30 pt-8">
      <h2 class="font-display text-cosmic-gold text-xl mb-4">Dernières lectures</h2>
      <div class="text-cosmic-text-dim text-sm italic">
        <p id="loading-placeholder">Chargement de tes lectures récentes…</p>
      </div>
    </section>
  </div>

  <script>
    import { api } from '../../lib/api';

    (async () => {
      try {
        const resp = await api.profile();
        if (resp.ok && resp.profile?.pseudo) {
          document.getElementById('welcome-pseudo')!.textContent =
            `Bienvenue ${resp.profile.pseudo}`;
        }
      } catch {}
    })();
  </script>
</AppLayout>
