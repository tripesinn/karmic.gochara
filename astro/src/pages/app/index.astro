---
// src/pages/app/index.astro — Dashboard connecté
import AppLayout from '../../layouts/AppLayout.astro';
import type { User } from '../../lib/types';
import { api } from '../../lib/api';

// SSR check — Astro SSG n'a pas accès aux cookies côté serveur,
// la vérification réelle se fait côté client dans AppLayout.
// En SSG, on rend la page statique; l'auth check client-side
// redirige si non connecté.
---

<AppLayout title="Mon espace — Karmic Gochara">
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-12">
    <!-- Local AI Banner -->
    <div id="local-ai-banner" class="hidden animate-fade-in bg-gradient-to-r from-emerald-900/40 to-cosmic-void border border-emerald-500/30 rounded-xl p-4 text-center">
      <p class="text-sm text-emerald-400 font-medium flex items-center justify-center gap-2">
        <span class="animate-pulse">✨</span> Puissance locale détectée : L'application utilise l'IA de votre appareil pour garantir une confidentialité totale.
      </p>
    </div>



    <!-- Welcome -->
    <section class="text-center animate-fade-in">
      <h1 class="text-4xl sm:text-5xl font-display text-cosmic-gold mb-3" data-i18n="welcome.title">✦ Bon retour</h1>
      <p class="text-cosmic-text-dim text-lg" id="welcome-pseudo" data-i18n="welcome.subtitle">Bienvenue dans ton espace</p>
      <p class="text-cosmic-text-dim text-sm mt-2">
        <a href="/register/index.html" class="text-cosmic-gold hover:underline font-medium" data-i18n="welcome.complete_profile">✦ Compléter mon profil →</a>
      </p>
      <p class="mt-4">
        <button id="settings-btn" class="px-4 py-1.5 rounded-full border border-cosmic-border bg-cosmic-void/40 text-xs text-cosmic-text hover:text-cosmic-gold hover:border-cosmic-gold transition-all">
          ⚙️ Réglages
        </button>
      </p>
    </section>

    <!-- Soul Debug du Jour (X-Bot Equivalent) -->
    <section id="soul-debug-card" class="border border-cosmic-border bg-cosmic-void/80 rounded-xl p-6 sm:p-8 space-y-4 max-w-2xl mx-auto text-center hidden">
      <h2 class="text-lg font-display text-cosmic-gold flex items-center justify-center gap-2">
        <span>🗝️</span> <span>Miroir de l'âme du Jour</span>
      </h2>
      <div id="soul-debug-content" class="text-sm italic text-cosmic-text leading-relaxed">
        Chargement de ton miroir céleste…
      </div>
      <div id="soul-debug-rating" class="flex justify-center gap-4 pt-2 hidden">
        <button id="btn-sd-up" class="px-3 py-1 bg-cosmic-void/40 border border-cosmic-border rounded hover:border-emerald-500 hover:text-emerald-400 transition-all">👍</button>
        <button id="btn-sd-down" class="px-3 py-1 bg-cosmic-void/40 border border-cosmic-border rounded hover:border-rose-500 hover:text-rose-400 transition-all">👎</button>
      </div>
      <span id="sd-rating-status" class="text-[10px] text-cosmic-text-dim block mt-1"></span>
      <p class="text-[10px] text-cosmic-text-dim/60">Généré par Grok (xAI) • Option B point chaud</p>
    </section>


    <!-- Quick actions -->
    <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a
        href="/app/lecture/index.html"
        class="group p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center"
      >
        <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-500">🌟</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1" data-i18n="nav.reading">Gochara</h3>
        <p class="text-cosmic-text-dim text-sm" data-i18n="nav.reading_desc">Découvrez vos transits planétaires</p>
      </a>

      <a
        id="nav-carte-link"
        href="/app/carte/index.html"
        class="group p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center cursor-pointer"
      >
        <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-500">📊</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1" data-i18n="nav.chart">Carte Astrale</h3>
        <p class="text-cosmic-text-dim text-sm" data-i18n="nav.chart_desc">Explore tes transits planétaires</p>
      </a>

      <a
        href="/app/biorhythm/index.html"
        class="group p-6 rounded-xl border border-cosmic-border bg-cosmic-void/60
               hover:border-cosmic-gold/40 transition-all duration-500 text-center"
      >
        <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-500">⌁</div>
        <h3 class="font-display text-cosmic-gold text-lg mb-1">Biorythmes</h3>
        <p class="text-cosmic-text-dim text-sm">Suis tes pics de densité lunaire</p>
      </a>

    </section>

    <!-- Agenda Karmique -->
    <section id="calendar-card" class="hidden border border-cosmic-border rounded-xl bg-cosmic-void/80 p-6 sm:p-10 space-y-4">
      <h2 class="text-xl font-display text-cosmic-gold flex items-center gap-2">
        <span>✦</span> <span data-i18n="calendar.title">Mon Agenda Karmique</span>
      </h2>
      <p class="text-sm text-cosmic-text-dim leading-relaxed" data-i18n="calendar.desc">
        Synchronise tes transits karmiques exacts (orbe &lt; 1.0°) directement dans ton application d'agenda préférée (Google Calendar, Apple Calendar, Outlook) pour recevoir des notifications lors des pics célestes.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 pt-2">
        <a
          id="subscribe-calendar-btn"
          href="#"
          class="flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg border border-cosmic-gold/50
                 text-cosmic-gold bg-cosmic-gold/10 text-sm transition-all duration-300
                 hover:bg-cosmic-gold hover:text-cosmic-bg font-display tracking-wider active:scale-95 text-center"
        >
          <span data-i18n="calendar.subscribe">✦ S'abonner à l'Agenda</span>
        </a>
        <button
          id="copy-calendar-url-btn"
          class="px-4 py-2.5 rounded-lg border border-cosmic-border bg-cosmic-void/40
                 text-xs text-cosmic-text hover:text-cosmic-gold hover:border-cosmic-gold transition-all"
          data-i18n="calendar.copy"
        >
          Copier le lien iCal
        </button>
      </div>
    </section>

    <!-- Recent readings placeholder -->
    <section class="border-t border-cosmic-border/30 pt-8">
      <h2 class="font-display text-cosmic-gold text-xl mb-4" data-i18n="readings.recent">Dernières lectures</h2>
      <div class="text-cosmic-text-dim text-sm italic">
        <p id="loading-placeholder" data-i18n="readings.loading">Chargement de tes lectures récentes…</p>
      </div>
    </section>
  </div>

  <script>
    import { api } from '../../lib/api';
    import { i18n } from '../../lib/i18n';
    import { triggerUpgrade } from '../../lib/upgrade';

    (async () => {
      // Détection IA locale
      api.detectLocalAI().then((url) => {
        if (url) {
          const banner = document.getElementById('local-ai-banner');
          if (banner) banner.classList.remove('hidden');
          const settingsBtn = document.getElementById('settings-btn');
          if (settingsBtn) settingsBtn.textContent = '⚙️ Réglages & IA';
        } else {
          // Afficher la suggestion d'installation d'une IA locale
          // uniquement si le smartphone semble assez puissant
          // navigator.deviceMemory renvoie la RAM en Go (seulement sur WebView/Chrome)
          const ram = (navigator as any).deviceMemory;
          const cores = navigator.hardwareConcurrency;
          
          // Si les API sont supportées, on vérifie que l'appareil a >= 6Go de RAM et >= 6 cœurs
          const hasEnoughRam = ram ? ram >= 6 : true;
          const hasEnoughCores = cores ? cores >= 6 : true;

          if (hasEnoughRam && hasEnoughCores) {
            const suggestion = document.getElementById('local-ai-suggestion');
            if (suggestion) suggestion.classList.remove('hidden');
            const settingsBtn = document.getElementById('settings-btn');
            if (settingsBtn) settingsBtn.textContent = '⚙️ Réglages & IA';
          }
        }
      });

      try {
        if (new URLSearchParams(window.location.search).get('upgrade') === 'true') {
          triggerUpgrade('pro').catch(err => {
            console.error(err);
            alert(err.message || "Impossible d'initier le paiement.");
          });
        }
        const resp = await api.profile();
        if (resp.ok && resp.profile?.pseudo) {
          const pseudo = resp.profile.pseudo;
          document.getElementById('welcome-pseudo')!.textContent =
            `${i18n.t('welcome.subtitle')} ${pseudo}`;

          // Charger le Soul Debug
          const debugCard = document.getElementById('soul-debug-card')!;
          const debugContent = document.getElementById('soul-debug-content')!;
          const ratingDiv = document.getElementById('soul-debug-rating')!;
          const ratingStatus = document.getElementById('sd-rating-status')!;
          const btnUp = document.getElementById('btn-sd-up')!;
          const btnDown = document.getElementById('btn-sd-down')!;
          debugCard.classList.remove('hidden');
          
          api.soulDebug().then(res => {
            if (res.ok && res.soul_debug) {
              debugContent.textContent = res.soul_debug;
              ratingDiv.classList.remove('hidden');
              
              const handleRate = async (rating: number) => {
                ratingStatus.textContent = "Envoi du feedback...";
                btnUp.setAttribute('disabled', 'true');
                btnDown.setAttribute('disabled', 'true');
                try {
                  const rateRes = await api.rateSoulDebug(rating, res.soul_debug!);
                  if (rateRes.ok) {
                    ratingStatus.textContent = rating === 1 ? "Merci pour ton retour! 👍" : "Retour enregistré 🔧";
                  } else {
                    ratingStatus.textContent = "Erreur lors de l'enregistrement.";
                    btnUp.removeAttribute('disabled');
                    btnDown.removeAttribute('disabled');
                  }
                } catch {
                  ratingStatus.textContent = "Erreur réseau.";
                  btnUp.removeAttribute('disabled');
                  btnDown.removeAttribute('disabled');
                }
              };
              
              btnUp.onclick = () => handleRate(1);
              btnDown.onclick = () => handleRate(-1);
            } else {
              debugContent.textContent = "Ton miroir de l'âme n'a pas pu être généré aujourd'hui.";
            }
          }).catch(async () => {
            // ── Fallback local (Gemma natif) UNIQUEMENT si l'utilisateur a choisi le mode native ──
            const storedSettings = localStorage.getItem('karmic_ai_settings');
            let localMode = 'cloud';
            try { if (storedSettings) localMode = (JSON.parse(storedSettings).localMode) || 'cloud'; } catch (e) {}
            if (localMode === 'native' && capacitorBridge.isNative()) {
              try {
                debugContent.textContent = "Invocation de l'Oracle local (Gemma)…";
                const lang = i18n.detect();
                const promptRes = await fetch(`/api/soul_debug_prompt?lang=${encodeURIComponent(lang)}`, { credentials: 'include' });
                const promptData = await promptRes.json();
                if (!promptRes.ok || !promptData.ok) throw new Error(promptData.error || 'prompt local indisponible');
                await capacitorBridge.gemma.prepareModel(false);
                const localText = await capacitorBridge.gemma.generate(promptData.system, promptData.user, 'soul_debug', lang, {});
                if (localText) {
                  debugContent.textContent = localText;
                  ratingDiv.classList.remove('hidden');
                  return;
                }
                throw new Error('Gemma sans reponse');
              } catch (e: any) {
                debugContent.textContent = "Erreur de connexion au serveur d'Oracle. (fallback local impossible : " + (e.message || e) + ")";
              }
            } else {
              debugContent.textContent = "Erreur de connexion au serveur d'Oracle.";
            }
          });


          // Change button to Edit Profile
          const editLink = document.querySelector('a[href="/register/index.html"]');
          if (editLink) {
            editLink.textContent = "✦ Éditer mon profil →";
            editLink.removeAttribute("data-i18n");
          }

          // Configuration agenda
          const plan = (resp.profile.plan || 'free').toLowerCase();
          const calendarCard = document.getElementById('calendar-card')!;
          calendarCard.classList.remove('hidden');

          const subBtn = document.getElementById('subscribe-calendar-btn') as HTMLAnchorElement;
          const copyBtn = document.getElementById('copy-calendar-url-btn') as HTMLButtonElement;

          if (plan === 'pro' || plan === 'subscription' || plan === 'essential' || plan === 'illimite') {
            const calendarUrl = api.getCalendarUrl(pseudo);
            subBtn.href = calendarUrl;
            subBtn.target = '_blank';
            
            copyBtn.addEventListener('click', async () => {
              try {
                await navigator.clipboard.writeText(calendarUrl);
                const originalText = copyBtn.textContent;
                copyBtn.textContent = i18n.t('calendar.copied');
                setTimeout(() => { copyBtn.textContent = originalText; }, 2000);
              } catch (err) {
                console.error('Failed to copy', err);
              }
            });
          } else {
            // Plan gratuit : cacher le lien Carte Astrale
            const carteLink = document.getElementById('nav-carte-link');
            if (carteLink) carteLink.style.display = 'none';

            // Plan gratuit : rediriger vers l'upgrade pour l'agenda
            subBtn.innerHTML = `<span>${i18n.t('calendar.subscribe_premium')}</span>`;
            subBtn.addEventListener('click', async (e) => {
              e.preventDefault();
              try {
                await triggerUpgrade('subscription');
              } catch (err: any) {
                console.error(err);
                alert(err.message || "Impossible d'initier le paiement.");
              }
            });
            copyBtn.classList.add('hidden');
          }
        }
      } catch {}
    })();
  </script>
</AppLayout>
