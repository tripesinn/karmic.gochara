---
// src/pages/app/chat.astro — Chat Karmique
import AppLayout from '../../layouts/AppLayout.astro';
import ChatBox from '../../components/ChatBox.astro';
---

<AppLayout title="Chat Karmique — Karmic Gochara">
  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- Header -->
    <section class="mb-8 animate-fade-in">
      <div class="flex items-center gap-3 mb-2">
        <a
          href="/app/index.html"
          class="text-cosmic-text-dim hover:text-cosmic-gold
                 transition-colors text-sm font-display"
        >
          ← Retour
        </a>
      </div>
      <h1 class="text-3xl sm:text-4xl font-display text-cosmic-gold">
        💬 Chat Karmique
      </h1>
      <p class="text-cosmic-text-dim text-sm mt-2">
        Pose tes questions à l&rsquo;IA karmique. Les réponses
        sont générées à partir de ton thème natal.
      </p>
    </section>

    <!-- Chat component -->
    <ChatBox />

  </div>
</AppLayout>
