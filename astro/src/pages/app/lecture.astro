---
// src/pages/app/lecture.astro — Lecture karmique quotidienne
// Composant client-side avec streaming SSE pour l'analyse
import AppLayout from '../../layouts/AppLayout.astro';
import ChatBox from '../../components/ChatBox.astro';
import { capacitorBridge } from '../../lib/capacitor-bridge';
---

<AppLayout title="Lecture — Karmic Gochara">
  <div class="max-w-3xl mx-auto px-4 py-12 space-y-8">
    <h1 class="text-3xl sm:text-4xl font-display text-cosmic-gold text-center" data-i18n="lecture.title">✦ Lecture du Jour</h1>
    <p class="text-cosmic-text-dim text-center" data-i18n="lecture.subtitle">
      Reçois ton analyse karmique personnalisée en temps réel.
    </p>

    <!-- Écran principal de lecture -->
    <div id="main-reading-card" class="border border-cosmic-border rounded-xl bg-cosmic-void/60 p-6 sm:p-10 min-h-[300px] flex flex-col justify-between">
      <div>
        <div id="reading-status" class="text-cosmic-text-dim flex justify-center items-center gap-3 italic py-10 w-full">
          <svg class="animate-spin h-5 w-5 text-cosmic-gold flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          <span>Prépare-toi &hellip;</span>
        </div>
        <div id="reading-output" class="text-cosmic-text leading-relaxed space-y-4 whitespace-pre-wrap"></div>
      </div>
      
      <div id="copy-container" class="hidden mt-6 flex justify-end">
        <button 
          id="copy-reading-btn" 
          class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-cosmic-gold/30 bg-cosmic-void/80 text-xs text-cosmic-gold/70 transition-all hover:text-cosmic-gold hover:border-cosmic-gold active:scale-95"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
          <span data-i18n="lecture.copy">Copier la lecture</span>
        </button>
      </div>
    </div>

    <!-- Écran de téléchargement de modèle (uniquement natif si modèle manquant) -->
    <div id="model-download-card" class="hidden border border-cosmic-border rounded-xl bg-cosmic-void/80 p-6 sm:p-10 space-y-6">
      <h2 class="text-xl font-display text-cosmic-gold flex items-center gap-2">
        <span>✦</span> Modèle Local requis (Gemma 4)
      </h2>
      <p class="text-sm text-cosmic-text-dim leading-relaxed">
        Pour garantir une confidentialité absolue, l'IA Gemma 4 E2B-IT s'exécute directement sur votre processeur (100% hors-ligne).
        Veuillez choisir un dossier de stockage (ex: Téléchargements) où le modèle (2.58 Go) sera sauvegardé ou lu s'il y est déjà présent.
      </p>

      <!-- Section Bouton / Barre de progression -->
      <div class="space-y-4 p-4 rounded-lg bg-cosmic-void/40 border border-cosmic-border/50">
        <div id="download-progress-container" class="hidden space-y-2">
          <div class="flex justify-between text-xs text-cosmic-text-dim">
            <span>Téléchargement du modèle...</span>
            <span id="download-percentage">0%</span>
          </div>
          <div class="w-full bg-cosmic-bg/60 rounded-full h-3 overflow-hidden border border-cosmic-border/30">
            <div id="download-progress-bar" class="bg-cosmic-gold h-full w-0 transition-all duration-300 shadow-[0_0_10px_rgba(201,168,76,0.5)]"></div>
          </div>
          <div id="download-bytes-info" class="text-[10px] text-cosmic-text-dim text-right">
            0 Mo / 0 Mo
          </div>
        </div>

        <button
          id="request-permission-btn"
          class="hidden w-full py-3 mb-2 font-display tracking-wider rounded-lg border border-cosmic-gold/50
                 text-cosmic-gold bg-cosmic-gold/10 transition-all duration-500
                 hover:bg-cosmic-gold hover:text-cosmic-bg
                 hover:shadow-[0_0_20px_rgba(201,168,76,0.25)]"
        >
          ✦ Choisir le dossier de stockage du modèle
        </button>

        <button
          id="start-download-btn"
          class="w-full py-3 font-display tracking-wider rounded-lg border border-cosmic-gold/50
                 text-cosmic-gold bg-cosmic-gold/10 transition-all duration-500
                 hover:bg-cosmic-gold hover:text-cosmic-bg
                 hover:shadow-[0_0_20px_rgba(201,168,76,0.25)]"
        >
          ✦ Démarrer le téléchargement (2.58 Go)
        </button>

        <div class="text-center text-xs text-cosmic-text-dim py-1">ou</div>

        <button
          id="select-local-model-btn"
          class="w-full py-2.5 font-display text-xs tracking-wider rounded-lg border border-cosmic-border
                 text-cosmic-text-dim bg-cosmic-void/20 transition-all duration-500
                 hover:border-cosmic-gold hover:text-cosmic-gold hover:bg-cosmic-gold/5"
        >
          📁 Importer un fichier local (.litertlm)
        </button>
      </div>

      <!-- Instructions détaillées -->
      <details class="group border border-cosmic-border/30 rounded-lg p-3 text-xs bg-cosmic-void/20">
        <summary class="cursor-pointer font-display text-cosmic-text hover:text-cosmic-gold select-none flex justify-between items-center">
          <span>Besoin d'aide ? Instructions et options de téléchargement</span>
          <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
        </summary>
        <div class="mt-3 space-y-4 text-cosmic-text-dim leading-relaxed border-t border-cosmic-border/20 pt-3">
          <div>
            <h4 class="font-bold text-cosmic-gold mb-1">Option A : Téléchargement direct depuis l'application</h4>
            <p>
              Le téléchargement commencera directement en arrière-plan. Il est conseillé de rester connecté à un réseau Wi-Fi et de brancher votre téléphone sur secteur.
            </p>
          </div>
          <div>
            <h4 class="font-bold text-cosmic-gold mb-1">Option B : Installation manuelle via ordinateur (Plus rapide)</h4>
            <p>
              Si vous préférez économiser la batterie de votre téléphone ou utiliser une connexion plus rapide, vous pouvez le télécharger depuis un ordinateur :
            </p>
            <ol class="list-decimal list-inside mt-2 space-y-1">
              <li>Cliquez sur <a href="https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/main/gemma-4-E2B-it.litertlm" target="_blank" class="text-cosmic-gold underline hover:text-white">ce lien direct de téléchargement</a> (2.58 Go).</li>
              <li>Transférez le fichier <code>gemma-4-E2B-it.litertlm</code> sur votre téléphone (par câble USB, Google Drive, etc.).</li>
              <li>Sur l'application, choisissez le dossier où vous avez placé ce fichier, il sera automatiquement détecté !</li>
            </ol>
          </div>
        </div>
      </details>
    </div>

    <!-- Actions principales -->
    <div class="flex flex-col items-center gap-4 sm:flex-row justify-center mt-6">
      <button
        id="btn-daily-reading"
        class="px-6 py-3 font-display tracking-wider rounded-full border border-cosmic-gold/50
               text-cosmic-gold transition-all duration-300
               hover:bg-cosmic-gold hover:text-cosmic-bg
               hover:shadow-[0_0_20px_rgba(201,168,76,0.3)]
               disabled:opacity-50 disabled:cursor-not-allowed"
        onclick="startReading('daily')"
      >
        ✦ Lecture Quotidienne
      </button>
      <button
        id="btn-full-synthesis"
        class="px-6 py-3 font-display tracking-wider rounded-full bg-cosmic-gold text-cosmic-bg 
               border border-transparent transition-all duration-300
               hover:bg-[#E5BE5C] hover:shadow-[0_0_30px_rgba(201,168,76,0.5)]
               disabled:opacity-50 disabled:cursor-not-allowed"
        onclick="startReading('full')"
      >
        ✦ Synthèse Complète (Premium)
      </button>
    </div>

    <!-- Chat Karmique Intégré -->
    <div id="integrated-chat-container" class="hidden animate-fade-in pt-8 border-t border-cosmic-border/30">
      <div class="text-center mb-6">
        <h2 class="text-2xl font-display text-cosmic-gold">💬 Oracle Karmique</h2>
        <p class="text-sm text-cosmic-text-dim mt-2">Pose tes questions à l'Oracle sur ta lecture du jour.</p>
      </div>
      <ChatBox />
    </div>
  </div>

  <script>
    import { api } from '../../lib/api';
    import { capacitorBridge } from '../../lib/capacitor-bridge';
    import { triggerUpgrade } from '../../lib/upgrade';
    import { Capacitor } from '@capacitor/core';
    import { i18n } from '../../lib/i18n';

    function today() {
      const d = new Date();
      return d.toISOString().slice(0, 10);
    }
    function now() {
      const d = new Date();
      return d.toTimeString().slice(0, 5);
    }

    function setReadingStatus(content: string, isErrorOrHtml = false) {
      const status = document.getElementById('reading-status');
      if (!status) return;
      if (!content) {
        status.style.display = 'none';
        return;
      }
      status.style.display = 'flex';
      status.className = "text-cosmic-text-dim flex justify-center items-center gap-3 italic py-10 w-full";
      if (isErrorOrHtml) {
        status.innerHTML = `<div class="w-full text-center">${content}</div>`;
      } else {
        status.innerHTML = `<svg class="animate-spin h-5 w-5 text-cosmic-gold flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>${content}</span>`;
      }
    }

    let controller: AbortController | null = null;
    let isDownloading = false;

    // Configurer le listener de progression natif si sous Capacitor
    if (Capacitor.isNativePlatform()) {
      const { GemmaSynthesis } = Capacitor.Plugins as any;
      if (GemmaSynthesis) {
        GemmaSynthesis.addListener('modelDownloadProgress', (data: { progress: number; bytes: number; total: number }) => {
          const progressContainer = document.getElementById('download-progress-container')!;
          const progressBar = document.getElementById('download-progress-bar')!;
          const percentageText = document.getElementById('download-percentage')!;
          const bytesText = document.getElementById('download-bytes-info')!;
          
          progressContainer.classList.remove('hidden');
          
          const progress = data.progress || 0;
          progressBar.style.width = `${progress}%`;
          percentageText.textContent = `${progress}%`;
          
          const downloadedMb = (data.bytes / (1024 * 1024)).toFixed(1);
          const totalMb = (data.total / (1024 * 1024)).toFixed(1);
          bytesText.textContent = `${downloadedMb} Mo / ${totalMb} Mo`;
        });
      }
    }

    async function checkModelAvailability() {
      if (!capacitorBridge.isNative()) return true;

      try {
        const memCheck = await capacitorBridge.gemma.getDeviceMemory();
        if (memCheck && memCheck.sufficient === false) {
          document.getElementById('model-download-card')?.classList.add('hidden');
          document.getElementById('main-reading-card')?.classList.remove('hidden');
          return true; // Proceed to reading, but it will fallback to cloud
        }

        const avail = await capacitorBridge.gemma.checkAvailability();
        // Cacher par défaut
        document.getElementById('request-permission-btn')?.classList.add('hidden');
        document.getElementById('start-download-btn')?.classList.remove('hidden');

        if (avail && avail.available) {
          document.getElementById('model-download-card')?.classList.add('hidden');
          document.getElementById('main-reading-card')?.classList.remove('hidden');
          return true;
        } else {
          document.getElementById('main-reading-card')?.classList.add('hidden');
          document.getElementById('model-download-card')?.classList.remove('hidden');
          
          if (avail && avail.status === 'permission_required') {
             document.getElementById('request-permission-btn')?.classList.remove('hidden');
             document.getElementById('start-download-btn')?.classList.add('hidden');
             document.getElementById('select-local-model-btn')?.classList.add('hidden');
          } else if (avail && avail.downloading) {
            isDownloading = true;
            document.getElementById('download-progress-container')?.classList.remove('hidden');
            document.getElementById('start-download-btn')?.classList.add('hidden');
          } else {
             document.getElementById('select-local-model-btn')?.classList.remove('hidden');
          }
          return false;
        }
      } catch (err) {
        console.error("Erreur checkAvailability :", err);
        return true; // En cas de doute, on tente
      }
    }

    function makeTextInteractive(element: HTMLElement) {
      const text = element.textContent || element.innerText || '';
      // Regex pour séparer par les points tout en gardant le point, 
      // ou on peut faire un split sur les points.
      // Une approche simple:
      const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
      
      element.innerHTML = '';
      
      sentences.forEach(sentence => {
        const trimmed = sentence.trim();
        if (!trimmed) {
           element.appendChild(document.createTextNode(sentence));
           return;
        }
        
        const span = document.createElement('span');
        span.textContent = sentence;
        span.className = "cursor-pointer hover:bg-cosmic-gold/20 hover:text-cosmic-gold transition-colors underline decoration-dashed decoration-cosmic-border/50 underline-offset-4";
        
        span.addEventListener('click', () => {
          if ((window as any).openChatWithQuote) {
            (window as any).openChatWithQuote(trimmed);
            document.getElementById('integrated-chat-container')?.scrollIntoView({ behavior: 'smooth' });
          }
        });
        
        element.appendChild(span);
      });

      // Ajouter l'indicateur
      const indicator = document.createElement('div');
      indicator.className = "text-center text-xs text-cosmic-gold mt-6 animate-pulse";
      indicator.innerHTML = "✦ Clique sur une phrase pour en discuter avec l'Oracle ✦";
      element.appendChild(indicator);
    }

    async function startReading(readingType: 'daily' | 'full' = 'daily') {
      const status = document.getElementById('reading-status')!;
      const output = document.getElementById('reading-output')!;
      const btnDaily = document.getElementById('btn-daily-reading') as HTMLButtonElement;
      const btnFull = document.getElementById('btn-full-synthesis') as HTMLButtonElement;

      // Détecter si l'utilisateur a configuré l'usage de l'IA locale (réglages de la modal)
      let useLocalConfig = false;
      let localMode = 'cloud';
      let networkHost = '';
      let networkModel = '';
      
      const storedSettings = localStorage.getItem('karmic_ai_settings');
      if (storedSettings) {
        try {
          const settings = JSON.parse(storedSettings);
          localMode = settings.localMode || 'cloud';
          useLocalConfig = localMode !== 'cloud';
          networkHost = settings.networkHost || 'http://192.168.1.92:11434';
          networkModel = settings.networkModel || 'gemma';
        } catch (e) {}
      }

      // Si l'utilisateur veut utiliser le local sur mobile natif, on fait les vérifications associées
      let forceCloudFallback = !useLocalConfig;
      
      if (localMode === 'native' && capacitorBridge.isNative() && !forceCloudFallback) {
        const memCheck = await capacitorBridge.gemma.getDeviceMemory();
        if (memCheck && memCheck.sufficient === false) {
          console.log("Device memory insufficient for local model. Forcing cloud fallback.");
          forceCloudFallback = true;
        } else {
          const hasModel = await checkModelAvailability();
          if (!hasModel) {
            // Si le modèle n'est pas dispo localement, au lieu de bloquer, on passe en Cloud de secours (roue de secours)
            console.log("Modèle local absent ou non-téléchargé. Basculement sur l'IA Cloud de secours.");
            forceCloudFallback = true;
          }
        }
      }

      if (controller) controller.abort();
      controller = new AbortController();

      setReadingStatus('Connexion à l&rsquo;oracle …');
      if (readingType === 'daily') {
        output.textContent = '';
      } else if (output.textContent) {
        output.textContent += '\n\n✦ SYNTHÈSE COMPLÈTE ✦\n\n';
      }
      if(btnDaily) btnDaily.disabled = true;
      if(btnFull) btnFull.disabled = true;
      document.getElementById('copy-container')?.classList.add('hidden');

      let pseudo = 'TestUser';
      let plan = 'free';
      try {
        const resp = await api.profile();
        if (resp.ok && resp.profile?.pseudo) {
          pseudo = resp.profile.pseudo;
          plan = resp.profile.plan || 'free';
        }
      } catch {}

      if (!pseudo) {
        setReadingStatus('Impossible de récupérer ton profil.', true);
        if(btnDaily) btnDaily.disabled = false;
        if(btnFull) btnFull.disabled = false;
        return;
      }

      if (readingType === 'full' && plan === 'free') {
        setReadingStatus(`
          <div class="text-center">
            <p class="text-red-400 mb-4">La synthèse karmique est réservée au plan premium.</p>
            <a href="/app/premium" class="px-4 py-2 bg-cosmic-gold text-cosmic-bg rounded-full text-sm font-display inline-block">
              Découvrir l'abonnement
            </a>
          </div>
        `, true);
        if(btnDaily) btnDaily.disabled = false;
        if(btnFull) btnFull.disabled = false;
        return;
      }

      try {
        if (localMode === 'network') {
          setReadingStatus('Calcul des transits...');
          const nowTime = new Date();
          const hour = nowTime.getHours();
          const minute = nowTime.getMinutes();
          const promptData = await api.synthesisPrompt({
            context: 'synthesis',
            date: today(),
            hour,
            minute,
            reading_type: readingType,
            is_local: true
          });

          if (!promptData || !promptData.ok) {
            throw new Error("Impossible de calculer les transits.");
          }

          setReadingStatus('Appel du serveur IA réseau…');
          
          const response = await fetch(`${networkHost}/v1/chat/completions`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer omlx_12345678910111213abcDEF'
            },
            body: JSON.stringify({
              model: networkModel,
              messages: [
                { role: 'system', content: promptData.system },
                { role: 'user', content: promptData.user }
              ],
              temperature: 0.7
            })
          });

          if (!response.ok) {
            throw new Error(`Erreur serveur IA réseau (${response.status})`);
          }

          const resData = await response.json();
          const reply = resData.choices?.[0]?.message?.content || resData.response;
          if (reply) {
            setReadingStatus('');
            output.textContent = reply;
            sessionStorage.setItem('last_lecture_output', reply);
            document.getElementById('copy-container')?.classList.remove('hidden');
            
            makeTextInteractive(output);
            document.getElementById('integrated-chat-container')?.classList.remove('hidden');
          } else {
            throw new Error("Le serveur IA réseau n'a pas renvoyé de texte.");
          }
        } else if (localMode === 'native' && capacitorBridge.isNative() && !forceCloudFallback) {
          setReadingStatus('Calcul des transits...');
          const nowTime = new Date();
          const hour = nowTime.getHours();
          const minute = nowTime.getMinutes();
          const promptData = await api.synthesisPrompt({
            context: 'synthesis',
            date: today(),
            hour,
            minute,
            reading_type: readingType,
            is_local: true
          });

          if (!promptData || !promptData.ok) {
            throw new Error("Impossible de calculer les transits.");
          }

          setReadingStatus('Initialisation de l&rsquo;Oracle local…');
          await capacitorBridge.gemma.prepareModel(false);

          setReadingStatus('Génération de ta lecture…');
          const response = await capacitorBridge.gemma.generate(
            promptData.system,
            promptData.user,
            "synthesis",
            i18n.detect()
          );

          if (response) {
            setReadingStatus('');
            output.textContent = response;
            sessionStorage.setItem('last_lecture_output', response);
            document.getElementById('copy-container')?.classList.remove('hidden');
            
            makeTextInteractive(output);
            document.getElementById('integrated-chat-container')?.classList.remove('hidden');
          } else {
            throw new Error("Gemma n'a pas répondu.");
          }
        } else {
          // Mode Web/Réseau (SSE) — Utilisé comme roue de secours ou en mode web
          const lang = i18n.detect();
          for await (const chunk of api.calculate({
            pseudo,
            transit_date: today(),
            transit_time: now(),
            reading_type: readingType
          })) {
            setReadingStatus('');
            if (chunk.text) {
              output.textContent += chunk.text;
            } else if (chunk.html) {
              output.innerHTML += chunk.html;
            }
          }
          setReadingStatus('');
          sessionStorage.setItem('last_lecture_output', output.textContent || output.innerHTML);
          document.getElementById('copy-container')?.classList.remove('hidden');
          
          makeTextInteractive(output);
          document.getElementById('integrated-chat-container')?.classList.remove('hidden');
        }
      } catch (err: any) {
        if (err.name !== 'AbortError') {
          console.error(err);
          if (err.message?.includes('subscription_required') || err.message?.includes('quota') || err.status === 429) {
            setReadingStatus(`
              <div class="text-center">
                <p class="text-red-400 mb-4">${err.message || 'La synthèse karmique est réservée au plan Lecture.'}</p>
                <a href="/app/premium" class="px-4 py-2 bg-cosmic-gold text-cosmic-bg rounded-full text-sm font-display inline-block">
                  Découvrir l'abonnement
                </a>
              </div>
            `, true);
          } else {
            setReadingStatus('La connexion karmique a été interrompue. ' + (err.message || ''), true);
          }
        }
      } finally {
        if(btnDaily) btnDaily.disabled = false;
        if(btnFull) btnFull.disabled = false;
        controller = null;
      }
    }
    
    // Rendre la fonction accessible globalement pour les événements onclick des boutons HTML
    (window as any).startReading = startReading;

    // Gérer l'action de téléchargement
    document.getElementById('request-permission-btn')?.addEventListener('click', async () => {
      await capacitorBridge.gemma.requestStoragePermission();
      checkModelAvailability();
    });

    document.getElementById('start-download-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('start-download-btn') as HTMLButtonElement;
      const progressContainer = document.getElementById('download-progress-container')!;
      
      btn.disabled = true;
      btn.textContent = "Téléchargement initié...";
      progressContainer.classList.remove('hidden');

      try {
        isDownloading = true;
        const res = await capacitorBridge.gemma.prepareModel(false);
        if (res && res.ok) {
          // Téléchargement et chargement réussis !
          document.getElementById('model-download-card')?.classList.add('hidden');
          document.getElementById('main-reading-card')?.classList.remove('hidden');
          startReading();
        } else {
          alert("Échec du téléchargement du modèle local.");
          btn.disabled = false;
          btn.textContent = "✦ Démarrer le téléchargement (2.58 Go)";
        }
      } catch (err: any) {
        console.error(err);
        alert(`Erreur : ${err.message || err}`);
        btn.disabled = false;
        btn.textContent = "✦ Démarrer le téléchargement (2.58 Go)";
      } finally {
        isDownloading = false;
      }
    });

    document.getElementById('select-local-model-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('select-local-model-btn') as HTMLButtonElement;
      const progressContainer = document.getElementById('download-progress-container')!;
      const statusText = document.getElementById('reading-status')!;
      
      btn.disabled = true;
      progressContainer.classList.remove('hidden');

      try {
        isDownloading = true;
        const res = await capacitorBridge.gemma.selectLocalModel();
        if (res && res.ok) {
          setReadingStatus('<div class="flex justify-center"><svg class="animate-spin h-5 w-5 text-cosmic-gold" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg></div> Initialisation de l\'Oracle local…', true);
          const prep = await capacitorBridge.gemma.prepareModel(false);
          if (prep && prep.ok) {
            document.getElementById('model-download-card')?.classList.add('hidden');
            document.getElementById('main-reading-card')?.classList.remove('hidden');
            startReading();
          } else {
            alert("Erreur lors de l'initialisation du modèle importé.");
          }
        } else {
          alert("Importation du modèle annulée ou échouée.");
        }
      } catch (err: any) {
        console.error(err);
        alert(`Erreur d'importation : ${err.message || err}`);
      } finally {
        isDownloading = false;
        btn.disabled = false;
      }
    });

    document.getElementById('refresh-btn')?.addEventListener('click', () => {
      sessionStorage.removeItem('last_lecture_output');
      startReading();
    });

    document.getElementById('copy-reading-btn')?.addEventListener('click', async () => {
      const text = document.getElementById('reading-output')?.textContent || '';
      if (!text) return;
      
      try {
        await navigator.clipboard.writeText(text);
        const btn = document.getElementById('copy-reading-btn')!;
        const originalText = btn.innerHTML;
        btn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-green-400">Copié !</span>
        `;
        setTimeout(() => {
          btn.innerHTML = originalText;
        }, 2000);
      } catch (err) {
        console.error("Échec de la copie :", err);
      }
    });

    // Lancement au chargement
    checkModelAvailability().then((available) => {
      if (available) {
        const savedOutput = sessionStorage.getItem('last_lecture_output');
        if (savedOutput) {
          const status = document.getElementById('reading-status');
          const output = document.getElementById('reading-output');
          if (status) setReadingStatus('');
          if (output) {
            output.textContent = savedOutput;
            makeTextInteractive(output);
          }
          document.getElementById('copy-container')?.classList.remove('hidden');
          document.getElementById('integrated-chat-container')?.classList.remove('hidden');
        } else {
          startReading();
        }
      }
    });
  </script>
</AppLayout>
