---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import DailyReading from '../components/DailyReading.astro';
---

<script>
  import { Capacitor } from '@capacitor/core';
  if (Capacitor.isNativePlatform()) {
    window.location.replace('/app');
  }
</script>

<BaseLayout title="Karmic Gochara — Biomécanique 4D & Doctrine">
  <div class="min-h-screen flex flex-col relative overflow-hidden">
    
    <!-- Background Decorators -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cosmic-gold/10 via-cosmic-bg to-cosmic-bg -z-10"></div>
    <div class="absolute top-1/4 left-0 w-96 h-96 bg-purple-900/10 blur-[100px] rounded-full -z-10 mix-blend-screen"></div>
    <div class="absolute bottom-1/4 right-0 w-96 h-96 bg-cosmic-gold/5 blur-[100px] rounded-full -z-10 mix-blend-screen"></div>

    <!-- Navigation Minimaliste -->
    <header class="max-w-6xl w-full mx-auto px-6 py-8 flex justify-between items-center relative z-10">
      <div class="font-display text-2xl text-cosmic-gold tracking-widest flex items-center gap-3">
        ✦ KARMIC GOCHARA
      </div>
      <div class="flex items-center gap-4">
         <a href="/login" class="px-5 py-2 rounded-full border border-cosmic-gold/50 text-cosmic-gold font-body text-sm hover:bg-cosmic-gold/10 transition-colors">
            Connexion
         </a>
      </div>
    </header>

    <main class="flex-1 flex flex-col items-center justify-center relative z-10">
      
      <!-- HERO SECTION -->
      <section class="max-w-4xl mx-auto px-6 py-20 text-center">
        <div class="inline-block mb-4 px-3 py-1 rounded-full border border-cosmic-border bg-cosmic-void/50 text-xs font-mono text-cosmic-text-dim tracking-widest">
          V2.0 — DOCTRINE SYNTHÉTIQUE
        </div>
        <h1 class="text-5xl md:text-7xl font-display text-cosmic-text mb-6 leading-tight">
          L'Alchimie des <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-cosmic-gold to-yellow-200">Cycles Cosmiques</span>
        </h1>
        <p class="text-xl md:text-2xl text-cosmic-text-dim font-body max-w-2xl mx-auto mb-12 leading-relaxed">
          Décryptez votre Biomécanique 4D grâce à notre IA embarquée locale et obtenez votre lecture quotidienne.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="#daily-reading" class="px-8 py-4 rounded-xl bg-cosmic-gold text-cosmic-bg font-display font-bold tracking-wider hover:bg-yellow-400 transition-all shadow-[0_0_20px_rgba(212,175,55,0.3)]">
            LECTURE DU JOUR
          </a>
          <a href="#" class="px-8 py-4 rounded-xl border border-cosmic-border bg-cosmic-void/80 text-cosmic-text font-display tracking-wider hover:border-cosmic-gold/50 transition-all flex items-center gap-3">
            <svg class="w-6 h-6 text-cosmic-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M17.523 15.3414C17.523 15.3414 16.208 16.1424 14.894 16.8434L17.523 15.3414ZM18.736 14.6054L21.433 13.0644C21.841 12.8314 21.841 12.2474 21.433 12.0144L18.723 10.4664L14.887 8.27541L18.736 14.6054ZM2.50299 4.38041C2.33699 4.54941 2.24399 4.81141 2.24399 5.14341V19.9364C2.24399 20.2684 2.33699 20.5294 2.50299 20.6994L2.56999 20.7634L12.923 10.4104V10.2244L2.56999 4.31641L2.50299 4.38041ZM13.844 11.3314L16.289 13.7764L13.844 11.3314ZM13.844 13.7664L2.91599 21.1444C2.69599 21.2924 2.44199 21.2824 2.28599 21.1894L13.844 13.7664ZM13.844 11.3314L2.28599 3.88941C2.44199 3.79641 2.69599 3.78641 2.91599 3.93541L13.844 11.3314Z"/></svg>
            APP ANDROID
          </a>
        </div>
      </section>

      <!-- FEATURES SECTION -->
      <section class="max-w-6xl mx-auto px-6 py-20 w-full relative z-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="p-8 rounded-2xl bg-cosmic-void/60 border border-cosmic-border backdrop-blur-md hover:border-cosmic-gold/30 transition-all">
            <div class="text-4xl mb-4">🧠</div>
            <h3 class="font-display text-xl text-cosmic-gold mb-3">IA Locale Avancée</h3>
            <p class="text-cosmic-text-dim leading-relaxed">
              Propulsé par Gemma 2B/4B INT4 directement sur votre appareil. Confidentialité absolue, vos données ne quittent jamais votre téléphone.
            </p>
          </div>
          <div class="p-8 rounded-2xl bg-cosmic-void/60 border border-cosmic-border backdrop-blur-md hover:border-cosmic-gold/30 transition-all">
            <div class="text-4xl mb-4">🔮</div>
            <h3 class="font-display text-xl text-cosmic-gold mb-3">Doctrine Personnalisée</h3>
            <p class="text-cosmic-text-dim leading-relaxed">
              Analyse complète de vos transits astrologiques pour générer une doctrine unique guidant vos choix quotidiens en fonction des astres.
            </p>
          </div>
          <div class="p-8 rounded-2xl bg-cosmic-void/60 border border-cosmic-border backdrop-blur-md hover:border-cosmic-gold/30 transition-all">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="font-display text-xl text-cosmic-gold mb-3">Mode Hors-Ligne</h3>
            <p class="text-cosmic-text-dim leading-relaxed">
              Consultez votre Biomécanique 4D où que vous soyez. L'application Android est fonctionnelle même sans connexion internet.
            </p>
          </div>
        </div>
      </section>

      <!-- DAILY READING PREVIEW -->
      <section id="daily-reading" class="max-w-4xl mx-auto px-6 py-20 w-full relative z-20">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl text-cosmic-text mb-4">Aperçu Quotidien</h2>
          <p class="text-cosmic-text-dim">Découvrez l'énergie du jour. Pour une analyse complète, téléchargez l'application mobile.</p>
        </div>
        
        <div class="bg-cosmic-void/80 border border-cosmic-border rounded-2xl overflow-hidden backdrop-blur-md p-6 sm:p-0">
          <DailyReading />
        </div>
      </section>

    </main>

    <footer class="border-t border-cosmic-border/30 bg-cosmic-bg py-8 text-center text-sm text-cosmic-text-dim relative z-20">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p>&copy; 2026 Karmic Gochara. Tous droits réservés.</p>
        <div class="flex gap-4">
          <a href="#" class="hover:text-cosmic-gold transition">Conditions</a>
          <a href="#" class="hover:text-cosmic-gold transition">Confidentialité</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>