---
// src/pages/index.astro
/**
 * Nouvelle page d'accueil Karmic Gochara
 * Hook: "Ton agent astrologue"
 * Layout: 2 colonnes, Mockup CSS Chat, Glassmorphism
 */
import LoginCard from '../components/LoginCard.astro';

const props = {
    title: "Karmic Gochara | Ton agent astrologue",
    description: "Découvrez votre chemin de vie à travers l'astrologie sidérale et discutez avec votre agent karmique personnel."
};
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>{props.title}</title>
    <meta name="description" content={props.description} />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0a0a08] text-[#f5f0e8] font-sans selection:bg-[#c9a84c]/30 min-h-screen overflow-x-hidden flex flex-col relative">

    <!-- Header minimaliste -->
    <header class="w-full p-6 lg:p-10 flex justify-between items-center z-20">
      <div class="flex items-center gap-3">
        <img src="/karmic-symbol.png" alt="Karmic Logo" class="w-10 h-10 rounded-full border border-[#c9a84c]/30" />
        <span class="text-[#c9a84c] font-display text-sm tracking-[0.2em] uppercase">Karmic Gochara</span>
      </div>
    </header>

    <main class="flex-1 flex flex-col lg:flex-row items-center justify-center max-w-7xl mx-auto w-full px-6 lg:px-12 gap-12 lg:gap-24 relative z-10">
      
      <!-- Lueur d'arrière-plan -->
      <div class="absolute top-1/2 left-1/2 lg:left-3/4 -translate-x-1/2 -translate-y-1/2 w-[300px] sm:w-[500px] h-[300px] sm:h-[500px] bg-[#c9a84c] rounded-full blur-[120px] sm:blur-[180px] opacity-15 pointer-events-none"></div>

      <!-- Colonne Gauche : Texte & CTA -->
      <div class="flex-1 flex flex-col items-center lg:items-start text-center lg:text-left animate-fade-in-up mt-8 lg:mt-0">
        <div class="inline-block px-4 py-1.5 rounded-full border border-[#c9a84c]/30 bg-[#c9a84c]/5 backdrop-blur-md mb-6">
          <span class="text-[#c9a84c] text-xs font-semibold tracking-wider uppercase">Nouveau : IA Karmique</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-display font-bold leading-tight mb-6 text-transparent bg-clip-text bg-gradient-to-br from-[#f5f0e8] to-[#c9a84c]">
          Ton agent<br/>astrologue
        </h1>
        
        <p class="text-[#8a8678] text-lg lg:text-xl font-light mb-10 max-w-lg leading-relaxed">
          Découvrez votre chemin de vie en astrologie sidérale et échangez en direct avec une IA entraînée sur la doctrine karmique.
        </p>

        <!-- Login Card -->
        <div class="w-full max-w-md relative group">
          <!-- Effet glow sous le login -->
          <div class="absolute -inset-1 bg-gradient-to-r from-[#c9a84c]/40 to-transparent rounded-2xl blur-lg opacity-30 group-hover:opacity-50 transition duration-500"></div>
          <div class="relative bg-[#141412]/80 backdrop-blur-xl border border-[#c9a84c]/20 p-6 sm:p-8 rounded-2xl shadow-2xl">
            <LoginCard />
          </div>
        </div>
      </div>

      <!-- Colonne Droite : Mockup Téléphone CSS -->
      <div class="flex-1 w-full max-w-sm lg:max-w-md animate-fade-in-up-delay relative mb-12 lg:mb-0">
        <!-- Contour du téléphone -->
        <div class="relative mx-auto w-[280px] sm:w-[320px] h-[580px] sm:h-[650px] bg-[#0a0a08] border-[8px] border-[#2a2a26] rounded-[2.5rem] shadow-[0_0_50px_rgba(201,168,76,0.15)] overflow-hidden">
          
          <!-- Encoche (Notch) -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-[#2a2a26] rounded-b-2xl z-20"></div>

          <!-- Interface du Chat -->
          <div class="absolute inset-0 bg-[#0f0f0c] flex flex-col">
            <!-- Top bar -->
            <div class="h-20 bg-gradient-to-b from-[#1a1a16] to-transparent flex items-end px-6 pb-4 z-10">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#c9a84c]/20 flex items-center justify-center border border-[#c9a84c]/40">
                  <span class="text-[#c9a84c] text-xs">✦</span>
                </div>
                <div>
                  <h3 class="text-[#f5f0e8] text-sm font-semibold">Chat Karmique</h3>
                  <p class="text-[#c9a84c] text-[10px] uppercase tracking-wider">En ligne</p>
                </div>
              </div>
            </div>

            <!-- Messages -->
            <div class="flex-1 p-5 flex flex-col gap-4 justify-end pb-8">
              <!-- Bulle Utilisateur -->
              <div class="self-end max-w-[85%] bg-[#2a2a26]/80 backdrop-blur-md border border-[#ffffff]/5 rounded-2xl rounded-tr-sm p-3 shadow-lg transform transition hover:-translate-y-1">
                <p class="text-sm text-[#e0e0e0] font-light leading-snug">
                  Que signifie mon Nœud Sud en Scorpion ?
                </p>
              </div>

              <!-- Bulle Bot -->
              <div class="self-start max-w-[90%] bg-gradient-to-br from-[#c9a84c]/10 to-transparent backdrop-blur-xl border border-[#c9a84c]/20 rounded-2xl rounded-tl-sm p-4 shadow-xl transform transition hover:-translate-y-1">
                <p class="text-sm text-[#f5f0e8] font-light leading-relaxed">
                  Le <span class="text-[#c9a84c] font-medium">Nœud Sud en Scorpion</span> indique un passé karmique marqué par des crises intenses. Votre but (Nœud Nord) est de trouver la paix et la stabilité matérielle en Taureau.
                </p>
              </div>
            </div>

            <!-- Input area -->
            <div class="p-4 bg-[#141412] border-t border-[#ffffff]/5 flex items-center gap-3">
              <div class="flex-1 h-10 rounded-full bg-[#2a2a26]/50 border border-[#ffffff]/5"></div>
              <div class="w-10 h-10 rounded-full bg-[#c9a84c]/20 flex items-center justify-center border border-[#c9a84c]/40">
                <div class="w-4 h-4 rounded-full bg-[#c9a84c]"></div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Reflet brillant sur le téléphone -->
        <div class="absolute inset-0 pointer-events-none bg-gradient-to-tr from-transparent via-[rgba(255,255,255,0.05)] to-transparent rounded-[2.5rem] transform -rotate-12 scale-110"></div>
      </div>
    </main>
  </body>
</html>

<style>
  .font-display {
    font-family: 'Cinzel', serif;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .animate-fade-in-up-delay {
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.3s;
  }
  body {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  }
</style>
