---
// src/components/LoginCard.astro — Final Navigation Fix with Error Handling
const isEmulator = import.meta.env.PUBLIC_FIREBASE_EMULATOR === 'true';
---

<section id="login-card" class="glass-panel text-center max-w-sm w-full mx-4 p-8 relative overflow-hidden">
  <div id="download-status" class="text-xs text-white/50 mb-2"></div>
  <div class="absolute -top-32 -left-32 w-64 h-64 bg-karmic-primary/20 rounded-full blur-3xl"></div>
  <button id="google-signin-btn" type="button" class="w-full flex items-center justify-center gap-3 py-4 px-6 text-base font-semibold rounded-xl bg-white text-gray-900 border border-white/20 transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,255,255,0.15)] active:scale-[0.98] disabled:opacity-40">
      <svg width="20" height="20" viewBox="0 0 48 48" class="shrink-0">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      <span data-i18n="login.google">Continuer avec Google</span>
    </button>



    <div id="login-message" class="text-sm min-h-5 mt-4 transition-all duration-300" role="alert"></div>
  </div>
</section>

<script>
  import capacitorBridge from '../lib/capacitor-bridge';
  if (capacitorBridge.isNative()) {
    setTimeout(async () => {
      try {
        const downloadStatus = document.getElementById("download-status");
        if (downloadStatus) downloadStatus.innerText = "Downloading model...";
        await capacitorBridge.gemma.downloadModel();
        if (downloadStatus) downloadStatus.innerText = "Download complete!";
      } catch(err: any) {
        const downloadStatus = document.getElementById("download-status");
        if (downloadStatus) downloadStatus.innerText = "Error: " + err;
      }
    }, 1000);
  }
</script>
<script>
  import { signInWithGoogle, signInTestUser } from '../lib/firebase-auth';
  import { auth } from '../lib/firebase';
  import { onAuthStateChanged } from '@firebase/auth';
  import { api, ApiError } from '../lib/api';

  const isEmulator = (import.meta as any).env?.PUBLIC_FIREBASE_EMULATOR === 'true';
  const testNewBtn = document.getElementById('test-new-user-btn') as HTMLButtonElement | null;
  const testExistingBtn = document.getElementById('test-existing-user-btn') as HTMLButtonElement | null;

  const googleBtn = document.getElementById('google-signin-btn') as HTMLButtonElement;
  const messageDiv = document.getElementById('login-message') as HTMLDivElement;
  let isNavigating = false;

  console.log('📍 [LOC] Pathname actuel:', window.location.pathname);

  // 🛡️ SÉCURITÉ : Si on est déjà dans /app ou sur /register, on ne redirige pas
  const _path = window.location.pathname;
  if (_path.includes('/app') || _path.includes('/register')) {
    console.log('🛡️ [AUTH] Page exclue de la redirection auto (/app ou /register), LoginCard ignoré.');
  } else {
    // On vérifie si on vient de tenter une redirection pour éviter la boucle
    if (sessionStorage.getItem('is_redirecting_to_register')) {
      console.log('⏳ [AUTH] Redirection déjà en cours, on ignore le check auto');
      isNavigating = true;
    }

    onAuthStateChanged(auth, async (user) => {
      if (user && !isNavigating) {
         console.log('✅ [AUTH] User détecté, vérification du profil...');
         // On vérifie d'abord si on a déjà un token valide pour éviter de re-login pour rien
         const currentToken = localStorage.getItem('karmic_token');
         if (currentToken) {
           try {
             const resp = await api.profile();
              if (resp.ok) {
                console.log('🚀 [NAV] Déjà connecté au backend, redirection /app/index.html');
                window.location.replace(`${window.location.origin}/app/index.html`);
                return;
              }
           } catch (e) {}
         }
         handleLoginSuccess(user);
      }
    });

    googleBtn?.addEventListener('click', async () => {
      sessionStorage.removeItem('is_redirecting_to_register');
      isNavigating = false;
      googleBtn.disabled = true;
      if (messageDiv) {
        messageDiv.textContent = 'Ouverture de Google...';
        messageDiv.className = 'text-sm mt-4 text-cosmic-gold animate-pulse';
      }
      try {
        console.log('🔗 [UI] Appel signInWithGoogle()...');
        const user = await signInWithGoogle();
        console.log('🔗 [UI] signInWithGoogle() réussi pour:', user.email);
        handleLoginSuccess(user);
      } catch (err: any) {
        console.error('❌ [UI] Erreur Google:', err);
        if (messageDiv) {
          messageDiv.textContent = err?.message || 'Erreur Google';
          messageDiv.className = 'text-sm mt-4 text-red-400';
        }
        googleBtn.disabled = false;
      }
    });

    // Boutons de test émulateur
    /*
    if (isEmulator && testNewBtn) {
      testNewBtn.addEventListener('click', async () => {
        testNewBtn.disabled = true;
        testNewBtn.textContent = '⏳ Création du compte test...';
        try {
          // Email unique avec timestamp → TOUJOURS un nouvel utilisateur
          const uniqueEmail = `test-${Date.now()}@karmic.dev`;
          const user = await signInTestUser(uniqueEmail);
          console.info('🧪 [TEST] Nouveau user connecté:', user.email);
          handleLoginSuccess(user);
        } catch (err: any) {
          console.error('❌ [TEST] Erreur:', err);
          if (messageDiv) {
            messageDiv.textContent = '❌ Erreur test : ' + (err?.message || 'Émulateur actif ?');
            messageDiv.className = 'text-sm mt-4 text-red-400';
          }
          testNewBtn.disabled = false;
          testNewBtn.textContent = '🧪 Test : Nouvel Utilisateur';
        }
      });
    }
    */

    if (isEmulator && testExistingBtn) {
      testExistingBtn.addEventListener('click', async () => {
        testExistingBtn.disabled = true;
        try {
          // Email fixe → récupère un user existant (teste le flow reconnexion)
          const user = await signInTestUser('test-fixed@karmic.dev');
          console.info('🧪 [TEST] User existant connecté:', user.email);
          handleLoginSuccess(user);
        } catch (err: any) {
          console.error('❌ [TEST] Erreur:', err);
          if (messageDiv) {
            messageDiv.textContent = '❌ Erreur test : ' + (err?.message || 'Émulateur actif ?');
            messageDiv.className = 'text-sm mt-4 text-red-400';
          }
          testExistingBtn.disabled = false;
        }
      });
    }
  }

  async function handleLoginSuccess(user: any) {
    if (isNavigating) {
      console.log('⏳ [AUTH] Navigation déjà en cours, on ignore.');
      return;
    }
    console.log('📡 [API] Tentative de connexion via Firebase ID Token pour:', user.email);
    try {
      const idToken = await user.getIdToken();
      const resp = await api.loginFirebase(user.email || '', idToken);
      console.log('📡 [API] Réponse reçue:', resp);

      const origin = window.location.origin;
      if (resp.ok) {
        isNavigating = true;
        if (messageDiv) {
          messageDiv.textContent = 'Connexion réussie. Chargement de votre espace...';
          messageDiv.className = 'text-sm mt-4 text-emerald-400 font-medium';
        }
        console.log('🚀 [NAV] Redirection vers /app/index.html ...');
        window.location.replace(`${origin}/app/index.html`);
      } else if (resp.needs_register) {
        console.log('📝 [NAV] Redirection vers inscription requise.');
        doRegisterRedirect(user, origin);
      } else {
        throw new Error(resp.error || 'Erreur inconnue');
      }
    } catch (err: any) {
      const origin = window.location.origin;
      if (err instanceof ApiError && err.data?.needs_register) {
        console.log('📝 [NAV] Profil inexistant détecté via ApiError (404)');
        doRegisterRedirect(user, origin);
        return;
      }

      console.error('❌ [API] Échec handleLoginSuccess:', err);
      if (messageDiv) {
        if (err.status === 503 || err.message?.includes('Service Unavailable') || err.message?.includes('Failed to fetch')) {
          messageDiv.textContent = 'Le service est momentanément indisponible ou en cours de mise à jour (Erreur 503). Veuillez réessayer dans quelques instants.';
        } else {
          messageDiv.textContent = err.message || 'Erreur serveur. Veuillez réessayer.';
        }
        messageDiv.className = 'text-sm mt-4 text-red-400';
      }
      isNavigating = false;
      googleBtn.disabled = false;
    }
  }

  function doRegisterRedirect(user: any, origin: string) {
    isNavigating = true;
    sessionStorage.setItem('is_redirecting_to_register', 'true');
    const params = `?email=${encodeURIComponent(user.email || '')}&name=${encodeURIComponent(user.displayName || '')}`;
    const url = `${origin}/register/index.html${params}`;
    console.log('📝 [NAV] Redirection vers inscription (URL explicite):', url);
    window.location.replace(url);
  }
</script>
