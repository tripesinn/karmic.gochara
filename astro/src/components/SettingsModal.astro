---
// src/components/SettingsModal.astro — Settings modal for user preferences
// Modal overlay triggered by a button with id "settings-btn" or URL hash #settings
// Client-side — inline <script> handles open/close and interactions

export interface Props {
  userId?: string;
  currentLang?: string;
  currentPlan?: string;
}

const { currentLang = 'fr', currentPlan = 'free' } = Astro.props;
---

<div
  id="settings-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Paramètres"
>
  <div
    class="relative w-full max-w-md mx-4 rounded-2xl border border-cosmic-border
           bg-cosmic-void/95 backdrop-blur-md shadow-2xl shadow-black/50"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-cosmic-border">
      <h2 class="font-display text-lg tracking-wider text-cosmic-gold">✦ Paramètres</h2>
      <button
        id="settings-close"
        class="w-8 h-8 flex items-center justify-center rounded-full
               text-cosmic-text-dim hover:text-cosmic-text hover:bg-cosmic-border/50
               transition-colors duration-300"
        aria-label="Fermer"
      >
        ✕
      </button>
    </div>

    <!-- Body -->
    <div class="px-6 py-6 space-y-6">

      <!-- Profile info -->
      <div>
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Profil</p>
        <div class="flex items-center gap-4 p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
          <div
            class="w-10 h-10 rounded-full border border-cosmic-gold/30
                   bg-cosmic-void flex items-center justify-center
                   font-display text-sm text-cosmic-gold"
          >
            ☿
          </div>
          <div class="flex-1 min-w-0">
            <p id="settings-pseudo" class="font-display text-sm text-cosmic-text truncate">—</p>
            <p id="settings-plan" class="font-body text-xs text-cosmic-text-dim mt-0.5">
              Plan {currentPlan === 'pro' ? 'Pro' : 'Gratuit'}
            </p>
          </div>
        </div>
      </div>

      <!-- Mode Hors-Ligne (AI) -->
      <div id="settings-ai-section" class="hidden">
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Offline AI Model</p>
        <div class="p-4 rounded-xl bg-cosmic-bg border border-cosmic-border space-y-4">
          
          <div>
            <label for="ai-model-select" class="block font-display text-sm text-cosmic-text mb-2">Preferred Model</label>
            <select id="ai-model-select" class="w-full bg-cosmic-void border border-cosmic-border rounded-lg px-3 py-2 text-sm text-cosmic-text focus:border-cosmic-gold outline-none">
              <option value="gemma-2b" data-url="https://huggingface.co/litert-community/gemma-2b-it-int4.task" data-filename="gemma-2b-it-int4.task">Gemma 2B INT4 (1.1 GB — Fast & Efficient)</option>
              <option value="gemma-4b" data-url="https://huggingface.co/litert-community/gemma-2-9b-it-int4.task" data-filename="gemma-4b-it-int4.task">Gemma 4B INT4 (2.5 GB — More Accurate)</option>
            </select>
          </div>

          <div id="ai-download-container">
            <button id="ai-download-btn" class="w-full py-2.5 rounded-lg border border-cosmic-gold text-cosmic-gold font-body text-sm hover:bg-cosmic-gold/10 transition-colors">
              Download Model
            </button>
            <div id="ai-progress-container" class="hidden mt-3">
              <div class="flex justify-between text-xs text-cosmic-text-dim mb-1">
                <span id="ai-progress-text">Downloading...</span>
                <span id="ai-progress-percent">0%</span>
              </div>
              <div class="w-full bg-cosmic-void rounded-full h-1.5 overflow-hidden">
                <div id="ai-progress-bar" class="bg-cosmic-gold h-1.5 rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>
          </div>
          
        </div>
      </div>

      <!-- Plan info -->
      <div id="settings-plan-section">
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Abonnement</p>
        <div class="p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
          {currentPlan === 'pro' ? (
            <div class="flex items-center gap-3">
              <span class="text-cosmic-gold text-lg">✦</span>
              <div>
                <p class="font-display text-sm text-cosmic-gold">Karmic Pro</p>
                <p class="font-body text-xs text-cosmic-text-dim mt-0.5">Accès illimité</p>
              </div>
            </div>
          ) : (
            <div class="flex items-center gap-3">
              <span class="text-cosmic-text-dim text-lg">✦</span>
              <div>
                <p class="font-display text-sm text-cosmic-text">Plan Gratuit</p>
                <p class="font-body text-xs text-cosmic-dim mt-0.5">
                  <a href="/app?upgrade=true" class="text-cosmic-gold hover:underline">Passer à Pro →</a>
                </p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-cosmic-border flex items-center justify-between">
      <a
        href="/logout"
        id="settings-logout"
        class="font-body text-xs text-cosmic-text-dim hover:text-red-400/80 transition-colors duration-300"
      >
        Se déconnecter
      </a>
      <p class="font-body text-[10px] text-cosmic-text-dim/40">Karmic Gochara v1.0</p>
    </div>
  </div>
</div>

<script>
  import capacitorBridge from '../lib/capacitor-bridge';

  // ── DOM refs ──
  const modal = document.getElementById('settings-modal')!;
  const closeBtn = document.getElementById('settings-close')!;
  const pseudoEl = document.getElementById('settings-pseudo')!;

  // ── Open / Close ──
  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    loadUserProfile();
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  async function loadUserProfile() {
    try {
      const res = await fetch('/api/profile', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      if (data.ok && data.profile) {
        pseudoEl.textContent = data.profile.pseudo || '—';
        // Update plan display if available
        const planSection = document.getElementById('settings-plan-section');
        if (planSection && data.profile.plan) {
          const isPro = data.profile.plan === 'pro';
          planSection.innerHTML = `
            <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Abonnement</p>
            <div class="p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
              <div class="flex items-center gap-3">
                <span class="${isPro ? 'text-cosmic-gold' : 'text-cosmic-text-dim'} text-lg">✦</span>
                <div>
                  <p class="font-display text-sm ${isPro ? 'text-cosmic-gold' : 'text-cosmic-text'}">${isPro ? 'Karmic Pro' : 'Plan Gratuit'}</p>
                  <p class="font-body text-xs text-cosmic-dim mt-0.5">${isPro ? 'Accès illimité' : '<a href="/app?upgrade=true" class="text-cosmic-gold hover:underline">Passer à Pro →</a>'}</p>
                </div>
              </div>
            </div>
          `;
        }
      }
    } catch {
      // Silent fail — keep default text
    }
  }

  // ── AI Settings Logic ──
  const aiSection = document.getElementById('settings-ai-section');
  const aiModelSelect = document.getElementById('ai-model-select') as HTMLSelectElement;
  const aiDownloadBtn = document.getElementById('ai-download-btn');
  const aiProgressContainer = document.getElementById('ai-progress-container');
  const aiProgressBar = document.getElementById('ai-progress-bar');
  const aiProgressPercent = document.getElementById('ai-progress-percent');
  const aiProgressText = document.getElementById('ai-progress-text');

  async function initAI() {
    if (!capacitorBridge.isNative() || !aiSection) return;
    aiSection.classList.remove('hidden');

    const savedModel = localStorage.getItem('kg_ai_model_id');
    if (savedModel && aiModelSelect) {
      aiModelSelect.value = savedModel;
      const option = aiModelSelect.options[aiModelSelect.selectedIndex];
      if (option) {
         capacitorBridge.gemma.setModel(option.value, option.dataset.url!, option.dataset.filename!);
      }
    }
    
    await updateModelStatus();
    
    aiModelSelect?.addEventListener('change', async () => {
      const option = aiModelSelect.options[aiModelSelect.selectedIndex];
      localStorage.setItem('kg_ai_model_id', option.value);
      await capacitorBridge.gemma.setModel(option.value, option.dataset.url!, option.dataset.filename!);
      await updateModelStatus();
    });

    aiDownloadBtn?.addEventListener('click', async () => {
      aiDownloadBtn.classList.add('hidden');
      aiProgressContainer?.classList.remove('hidden');
      aiProgressText!.textContent = 'Starting download...';
      
      capacitorBridge.gemma.addListener('modelDownloadProgress', (event: any) => {
        const pct = event.progress || 0;
        aiProgressBar!.style.width = `${pct}%`;
        aiProgressPercent!.textContent = `${pct}%`;
        
        if (event.bytes && event.total) {
          const mb = (event.bytes / 1024 / 1024).toFixed(1);
          const totalMb = (event.total / 1024 / 1024).toFixed(1);
          aiProgressText!.textContent = `Downloading (${mb} / ${totalMb} MB)`;
        }
        
        if (pct >= 100) {
          aiProgressText!.textContent = 'Ready';
          setTimeout(updateModelStatus, 1000);
        }
      });
      
      try {
        await capacitorBridge.gemma.downloadModel();
      } catch (err) {
        aiProgressText!.textContent = 'Download failed';
        aiDownloadBtn.classList.remove('hidden');
      }
    });
  }

  async function updateModelStatus() {
    const status = await capacitorBridge.gemma.getModelStatus();
    if (!status) return;
    
    if (status.downloaded) {
      aiDownloadBtn?.classList.add('hidden');
      aiProgressContainer?.classList.remove('hidden');
      aiProgressText!.textContent = 'Model is ready (Offline Mode Active)';
      aiProgressBar!.style.width = '100%';
      aiProgressPercent!.textContent = '100%';
    } else if (status.downloading) {
      aiDownloadBtn?.classList.add('hidden');
      aiProgressContainer?.classList.remove('hidden');
      aiProgressText!.textContent = 'Download in progress...';
    } else {
      aiDownloadBtn?.classList.remove('hidden');
      aiProgressContainer?.classList.add('hidden');
      aiDownloadBtn!.textContent = 'Download Model';
    }
  }

  // Initialize AI on load
  initAI();
</script>
