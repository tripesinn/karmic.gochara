---
// src/components/SettingsModal.astro — Settings modal for user preferences
// Modal overlay triggered by a button with id "settings-btn" or URL hash #settings
// Client-side — inline script block handles open/close and interactions

export interface Props {
  userId?: string;
  currentLang?: string;
  currentPlan?: string;
}

const { currentLang = 'fr', currentPlan = 'free' } = Astro.props;
---

<div
  id="settings-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Paramètres"
>
  <div
    class="relative w-full max-w-md mx-4 rounded-2xl border border-cosmic-border
           bg-cosmic-void/95 backdrop-blur-md shadow-2xl shadow-black/50"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-cosmic-border">
      <h2 class="font-display text-lg tracking-wider text-cosmic-gold">✦ Paramètres</h2>
      <button
        id="settings-close"
        class="w-8 h-8 flex items-center justify-center rounded-full
               text-cosmic-text-dim hover:text-cosmic-text hover:bg-cosmic-border/50
               transition-colors duration-300"
        aria-label="Fermer"
      >
        ✕
      </button>
    </div>

    <!-- Body -->
    <div class="px-6 py-6 space-y-6">

      <!-- Profile info -->
      <div>
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Profil</p>
        <div class="flex items-center gap-4 p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
          <div
            class="w-10 h-10 rounded-full border border-cosmic-gold/30
                   bg-cosmic-void flex items-center justify-center
                   font-display text-sm text-cosmic-gold"
          >
            ☿
          </div>
          <div class="flex-1 min-w-0">
            <p id="settings-pseudo" class="font-display text-sm text-cosmic-text truncate">—</p>
            <p id="settings-plan" class="font-body text-xs text-cosmic-text-dim mt-0.5">
              Plan {currentPlan === 'pro' ? 'Pro' : 'Gratuit'}
            </p>
          </div>
        </div>
      </div>

      <!-- Langue -->
      <div>
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3" data-i18n="settings.language">Langue</p>
        <div class="grid grid-cols-3 gap-2">
          <button
            id="lang-fr"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="fr"
          >
            Français
          </button>
          <button
            id="lang-en"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="en"
          >
            English
          </button>
          <button
            id="lang-es"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="es"
          >
            Español
          </button>
          <button
            id="lang-pt"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="pt"
          >
            Português
          </button>
          <button
            id="lang-nl"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="nl"
          >
            Nederlands
          </button>
          <button
            id="lang-de"
            class="lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs transition-all duration-300"
            data-lang="de"
          >
            Deutsch
          </button>
        </div>
      </div>

      <!-- Plan info -->
      <div id="settings-plan-section">
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3" data-i18n="settings.plan">Plan</p>
        <div class="p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
          {currentPlan === 'pro' ? (
            <div class="flex items-center gap-3">
              <span class="text-cosmic-gold text-lg">✦</span>
              <div>
                <p class="font-display text-sm text-cosmic-gold" data-i18n="plan.pro">Karmic Pro</p>
                <p class="font-body text-xs text-cosmic-text-dim mt-0.5" data-i18n="plan.unlimited">Accès illimité</p>
              </div>
            </div>
          ) : (
            <div class="flex items-center gap-3">
              <span class="text-cosmic-text-dim text-lg">✦</span>
              <div>
                <p class="font-display text-sm text-cosmic-text" data-i18n="plan.free">Plan Gratuit</p>
                <p class="font-body text-xs text-cosmic-dim mt-0.5">
                  <a href="/app/index.html?upgrade=true" class="text-cosmic-gold hover:underline" data-i18n="plan.upgrade">Passer à Pro →</a>
                </p>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Oracle Style -->
      <div>
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">Style de l'Oracle</p>
        <div class="relative p-4 rounded-xl bg-cosmic-bg border border-cosmic-border group">
          <select
            id="oracle-style"
            class="w-full px-3 py-2 rounded-lg border border-cosmic-border bg-cosmic-void text-xs text-cosmic-text focus:border-cosmic-gold focus:outline-none transition-colors appearance-none"
            disabled
          >
            <option value="chirurgical">Chirurgical (Direct & sans filtre)</option>
            <option value="bienveillant">Bienveillant (Doux & encourageant)</option>
            <option value="expert">Expert (Avec aspects & transits techniques)</option>
          </select>
          <div id="oracle-style-lock" class="absolute inset-0 z-10 flex items-center justify-end pr-6 cursor-pointer bg-black/20 rounded-xl" title="Passer à Pro pour changer de style">
            <span class="text-cosmic-gold text-xs font-display flex items-center gap-1 bg-cosmic-void px-2 py-1 rounded border border-cosmic-gold/30">🔒 PRO</span>
          </div>
        </div>
      </div>

      <!-- Testeurs / IA -->
      <div>
        <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3" data-i18n="settings.local_ai">Expérimental (Testeurs)</p>
        <div class="space-y-4 p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
          <div>
            <label for="local-ai-mode" class="block font-body text-xs text-cosmic-text-dim mb-1.5">
              Mode d'interprétation IA
            </label>
            <select
              id="local-ai-mode"
              class="w-full px-3 py-2 rounded-lg border border-cosmic-border bg-cosmic-void text-xs text-cosmic-text focus:border-cosmic-gold focus:outline-none transition-colors"
            >
              <option value="cloud">Désactivé (IA Cloud par défaut)</option>
              <option value="native">IA Interne Mobile (Gemma sur l'appareil)</option>
              <option value="network">Serveur IA Réseau (Ollama, oMLX...)</option>
            </select>
          </div>

          <!-- Configuration Réseau Locale -->
          <div id="local-network-config" class="hidden space-y-3 pt-3 border-t border-cosmic-border/30">
            <div>
              <label for="local-ai-host" class="block font-body text-[10px] text-cosmic-text-dim tracking-wider uppercase mb-1">
                Adresse & Port du Serveur
              </label>
              <input
                type="text"
                id="local-ai-host"
                placeholder="http://192.168.1.92:11434"
                class="w-full px-3 py-2 rounded-lg border border-cosmic-border bg-cosmic-void text-xs text-cosmic-text focus:border-cosmic-gold focus:outline-none transition-colors"
              />
            </div>
            <div>
              <label for="local-ai-model-name" class="block font-body text-[10px] text-cosmic-text-dim tracking-wider uppercase mb-1">
                Nom du Modèle
              </label>
              <input
                type="text"
                id="local-ai-model-name"
                placeholder="gemma"
                class="w-full px-3 py-2 rounded-lg border border-cosmic-border bg-cosmic-void text-xs text-cosmic-text focus:border-cosmic-gold focus:outline-none transition-colors"
              />
            </div>
          </div>

          <!-- Configuration Native Locale (Capacitor) -->
          <div id="local-native-config" class="hidden space-y-3 pt-3 border-t border-cosmic-border/30">
            <button
              id="settings-select-local-model-btn"
              class="w-full py-2 font-display text-xs tracking-wider rounded-lg border border-cosmic-gold/50 text-cosmic-gold bg-cosmic-gold/10 hover:bg-cosmic-gold hover:text-cosmic-bg transition-all"
            >
              📁 Importer un modèle (.litertlm)
            </button>
            <button
              id="settings-download-model-btn"
              class="w-full py-2 font-display text-xs tracking-wider rounded-lg border border-cosmic-border text-cosmic-text-dim bg-cosmic-void/20 hover:border-cosmic-gold hover:text-cosmic-gold hover:bg-cosmic-gold/5 transition-all"
            >
              ⬇️ Télécharger le modèle officiel (2.58 Go)
            </button>
            <div id="settings-download-progress-container" class="hidden space-y-2 mt-2">
              <div class="flex justify-between text-xs text-cosmic-text-dim">
                <span>Téléchargement...</span>
                <span id="settings-download-percentage">0%</span>
              </div>
              <div class="w-full bg-cosmic-bg/60 rounded-full h-2 overflow-hidden border border-cosmic-border/30">
                <div id="settings-download-progress-bar" class="bg-cosmic-gold h-full w-0 transition-all duration-300"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-cosmic-border flex items-center justify-between">
      <a
        href="/logout"
        id="settings-logout"
        class="font-body text-xs text-cosmic-text-dim hover:text-red-400/80 transition-colors duration-300"
        data-i18n="settings.logout"
      >
        Se déconnecter
      </a>
      <p class="font-body text-[10px] text-cosmic-text-dim/40">Karmic Gochara v1.5</p>
    </div>
  </div>
</div>

<script>
  import { i18n } from '../lib/i18n';
  import { capacitorBridge } from '../lib/capacitor-bridge';
  import { Capacitor } from '@capacitor/core';

  // ── DOM refs ──
  const modal = document.getElementById('settings-modal')!;
  const closeBtn = document.getElementById('settings-close')!;
  const pseudoEl = document.getElementById('settings-pseudo')!;
  const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;

  // ── Open / Close ──
  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    loadUserProfile();
    updateActiveLangBtn(i18n.detect());
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  async function loadUserProfile() {
    try {
      const res = await fetch('/api/profile', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      if (data.ok && data.profile) {
        pseudoEl.textContent = data.profile.pseudo || '—';
        // Update plan display if available
        const planSection = document.getElementById('settings-plan-section');
        if (planSection && data.profile.plan) {
          const planStr = (data.profile.plan || '').toLowerCase();
          const isPro = planStr === 'pro' || planStr === 'premium';
          planSection.innerHTML = `
            <p class="font-body text-xs text-cosmic-text-dim tracking-wider uppercase mb-3">${i18n.t('settings.plan')}</p>
            <div class="p-4 rounded-xl bg-cosmic-bg border border-cosmic-border">
              <div class="flex items-center gap-3">
                <span class="${isPro ? 'text-cosmic-gold' : 'text-cosmic-text-dim'} text-lg">✦</span>
                <div>
                  <p class="font-display text-sm ${isPro ? 'text-cosmic-gold' : 'text-cosmic-text'}">${isPro ? i18n.t('plan.pro') : i18n.t('plan.free')}</p>
                  <p class="font-body text-xs text-cosmic-dim mt-0.5">${isPro ? i18n.t('plan.unlimited') : `<a href="/app/index.html?upgrade=true" class="text-cosmic-gold hover:underline">${i18n.t('plan.upgrade')}</a>`}</p>
                </div>
              </div>
            </div>
          `;
          
          // Update Oracle Style Lock
          const oracleSelect = document.getElementById('oracle-style') as HTMLSelectElement;
          const oracleLock = document.getElementById('oracle-style-lock');
          if (oracleSelect && oracleLock) {
            if (isPro) {
              oracleSelect.disabled = false;
              oracleLock.style.display = 'none';
            } else {
              oracleSelect.disabled = true;
              oracleSelect.value = 'chirurgical';
              oracleLock.style.display = 'flex';
              
              // Force update in local storage to chirurgical if it was previously set to something else
              try {
                const stored = localStorage.getItem('karmic_ai_settings');
                if (stored) {
                  const settings = JSON.parse(stored);
                  if (settings.oracleStyle !== 'chirurgical') {
                    settings.oracleStyle = 'chirurgical';
                    localStorage.setItem('karmic_ai_settings', JSON.stringify(settings));
                  }
                }
              } catch (e) {}
            }
          }
        }
      }
    } catch {
      // Silent fail — keep default text
    }
  }

  // Helper to update active language UI style
  function updateActiveLangBtn(lang: string) {
    langBtns.forEach((btn) => {
      const isActive = btn.dataset.lang === lang;
      btn.className = `lang-btn px-2 py-2 rounded-xl border text-center font-body text-xs
        transition-all duration-300 ${
          isActive
            ? 'bg-cosmic-gold/15 border-cosmic-gold/50 text-cosmic-gold font-medium'
            : 'bg-cosmic-bg border-cosmic-border text-cosmic-text-dim/70 hover:border-cosmic-text-dim/30'
        }`;
    });
  }

  // ── Event listeners ──
  closeBtn.addEventListener('click', closeModal);

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  // Listen for settings button click
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('#settings-btn') || target.closest('[data-action="settings"]')) {
      openModal();
    }
  });

  // Listen for hash changes
  window.addEventListener('hashchange', () => {
    if (window.location.hash === '#settings') openModal();
  });
  if (window.location.hash === '#settings') openModal();

  // Langue buttons
  langBtns.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const selected = btn.dataset.lang || 'fr';
      await i18n.setLang(selected);
      updateActiveLangBtn(selected);
    });
  });

  // Initial language state
  updateActiveLangBtn(i18n.detect());

  // Listen to lang changes elsewhere
  window.addEventListener('karmic-lang-changed', (e: any) => {
    if (e.detail && e.detail.lang) {
      updateActiveLangBtn(e.detail.lang);
    }
  });

  // ── IA Locale Selection ──
  const modeSelect = document.getElementById('local-ai-mode') as HTMLSelectElement;
  const oracleStyleSelect = document.getElementById('oracle-style') as HTMLSelectElement;
  const configDiv = document.getElementById('local-network-config')!;
  const hostInput = document.getElementById('local-ai-host') as HTMLInputElement;
  const modelInput = document.getElementById('local-ai-model-name') as HTMLInputElement;

  if (modeSelect) {
    // Restaurer l'état initial
    const stored = localStorage.getItem('karmic_ai_settings');
    if (stored) {
      try {
        const settings = JSON.parse(stored);
        if (settings.localMode) {
          modeSelect.value = settings.localMode;
        } else if (settings.useLocal) {
          modeSelect.value = 'native';
        }
        
        if (settings.networkHost) hostInput.value = settings.networkHost;
        if (settings.networkModel) modelInput.value = settings.networkModel;
        if (settings.oracleStyle && oracleStyleSelect) oracleStyleSelect.value = settings.oracleStyle;
        
        toggleConfigVisibility(modeSelect.value);
      } catch (e) {}
    }

    const nativeConfigDiv = document.getElementById('local-native-config')!;

    function toggleConfigVisibility(mode: string) {
      if (mode === 'network') {
        configDiv.classList.remove('hidden');
        if(nativeConfigDiv) nativeConfigDiv.classList.add('hidden');
      } else if (mode === 'native') {
        configDiv.classList.add('hidden');
        if(nativeConfigDiv) nativeConfigDiv.classList.remove('hidden');
      } else {
        configDiv.classList.add('hidden');
        if(nativeConfigDiv) nativeConfigDiv.classList.add('hidden');
      }
    }

    function saveSettings() {
      const mode = modeSelect.value;
      const host = hostInput.value.trim();
      const model = modelInput.value.trim();
      
      const settings = {
        localMode: mode,
        useLocal: mode !== 'cloud',
        networkHost: host,
        networkModel: model,
        oracleStyle: oracleStyleSelect ? oracleStyleSelect.value : 'chirurgical'
      };
      localStorage.setItem('karmic_ai_settings', JSON.stringify(settings));
    }

    modeSelect.addEventListener('change', () => {
      toggleConfigVisibility(modeSelect.value);
      saveSettings();
    });

    if (oracleStyleSelect) {
      oracleStyleSelect.addEventListener('change', saveSettings);
    }
    
    const oracleLock = document.getElementById('oracle-style-lock');
    if (oracleLock) {
      oracleLock.addEventListener('click', () => {
        window.location.href = '/app/index.html?upgrade=true';
      });
    }

    hostInput.addEventListener('input', saveSettings);
    modelInput.addEventListener('input', saveSettings);

    // Native buttons
    const btnSelectNative = document.getElementById('settings-select-local-model-btn');
    const btnDownloadNative = document.getElementById('settings-download-model-btn');
    const nativeProgressContainer = document.getElementById('settings-download-progress-container');
    const nativeProgressBar = document.getElementById('settings-download-progress-bar');
    const nativeProgressText = document.getElementById('settings-download-percentage');

    if (Capacitor.isNativePlatform()) {
      const { GemmaSynthesis } = Capacitor.Plugins as any;
      if (GemmaSynthesis) {
        GemmaSynthesis.addListener('modelDownloadProgress', (data: { progress: number; bytes: number; total: number }) => {
          if (nativeProgressContainer && nativeProgressBar && nativeProgressText) {
            nativeProgressContainer.classList.remove('hidden');
            const progress = data.progress || 0;
            nativeProgressBar.style.width = `${progress}%`;
            nativeProgressText.textContent = `${progress}%`;
          }
        });
      }
    }

    if (btnSelectNative) {
      btnSelectNative.addEventListener('click', async () => {
        if (!capacitorBridge.isNative()) {
          alert("L'importation de modèle n'est disponible que sur l'application mobile native.");
          return;
        }
        try {
          const res = await capacitorBridge.gemma.selectLocalModel();
          if (res && res.ok) {
            alert("Modèle importé avec succès.");
          } else {
            alert("Importation annulée ou échouée.");
          }
        } catch (e: any) {
          alert(`Erreur d'importation : ${e.message || e}`);
        }
      });
    }

    if (btnDownloadNative) {
      btnDownloadNative.addEventListener('click', async () => {
        if (!capacitorBridge.isNative()) {
          alert("Le téléchargement n'est disponible que sur l'application mobile native.");
          return;
        }
        
        btnDownloadNative.textContent = "Téléchargement initié...";
        btnDownloadNative.setAttribute('disabled', 'true');
        if(nativeProgressContainer) nativeProgressContainer.classList.remove('hidden');

        try {
          // Ask for permission first if necessary
          await capacitorBridge.gemma.requestStoragePermission();
          const res = await capacitorBridge.gemma.prepareModel(false);
          if (res && res.ok) {
            alert("Modèle téléchargé et prêt.");
          } else {
            alert("Échec du téléchargement du modèle local.");
          }
        } catch (e: any) {
          alert(`Erreur : ${e.message || e}`);
        } finally {
          btnDownloadNative.textContent = "⬇️ Télécharger le modèle officiel (2.58 Go)";
          btnDownloadNative.removeAttribute('disabled');
        }
      });
    }
  }
</script>
