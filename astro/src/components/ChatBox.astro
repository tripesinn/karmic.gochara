---
// astro/src/components/ChatBox.astro
// This file is now purely a structural component for Astro, with all client-side logic moved to a script block.
---

<div class="border border-cosmic-border bg-cosmic-bg/50 rounded-xl p-4 sm:p-6 flex flex-col h-[500px] w-full mx-auto max-w-3xl">
  <div class="flex-1 overflow-y-auto space-y-4 pr-2 custom-scrollbar" id="chat-history">
    <!-- Messages will be injected here by JavaScript -->
  </div>
  <div class="chat-input-area flex items-center gap-2 mt-4">
    <input type="text" id="user-input" placeholder="Pose une question à l'Oracle..." class="flex-1 bg-cosmic-void border border-cosmic-border rounded px-4 py-3 text-cosmic-text placeholder-cosmic-text-dim focus:outline-none focus:border-cosmic-gold transition-colors" data-i18n="chat.placeholder" disabled>
    <button id="send-button" class="px-6 py-3 bg-cosmic-gold/10 text-cosmic-gold border border-cosmic-gold/30 rounded font-display tracking-wide hover:bg-cosmic-gold/20 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" data-i18n="chat.send" disabled>Envoyer</button>
  </div>
</div>

<script>
  import { capacitorBridge } from '../lib/capacitor-bridge';
  import { i18n } from '../lib/i18n';
  import { api } from '../lib/api';

  // --- Client-Side State Management ---
  interface Message {
    role: 'user' | 'assistant';
    content: string;
  }

  const welcomeMsg = i18n.t('chat.title') === '💬 Chat Karmique' 
    ? 'Bienvenue ! Posez-moi une question sur vos transits ou votre thème.'
    : 'Welcome! Ask me a question about your transits or natal chart.';

  const chatState = {
    messages: [{ role: 'assistant', content: welcomeMsg }] as Message[],
    currentAnalysisId: null as string | null,
    isLoading: false,
  };

  // --- DOM Elements ---
  const chatHistoryElement = document.getElementById('chat-history') as HTMLDivElement;
  const userInputElement = document.getElementById('user-input') as HTMLInputElement;
  const sendButtonElement = document.getElementById('send-button') as HTMLButtonElement;

  // Apply translations at launch
  i18n.apply();

  // Enable inputs at start
  if (userInputElement && sendButtonElement) {
    userInputElement.disabled = false;
    sendButtonElement.disabled = false;
  }

  // --- Mock/Web Fallback Functions ---
  const GemmaWebFallback = {
    generate: async (lightPrompt: string): Promise<string> => {
      console.log(`[Web Fallback] Sending light prompt to Gemma: ${lightPrompt.substring(0, 50)}...`);
      await new Promise(resolve => setTimeout(resolve, 1500));
      return i18n.detect() === 'fr'
        ? `[Gemma Web Fallback] Basé sur le contexte... (Utilisez l'application Android native pour exécuter localement Gemma).`
        : `[Gemma Web Fallback] Based on context... (Use the native Android app for true local Gemma inference).`;
    }
  };

  // --- State Update Functions ---
  const updateUI = () => {
    if (!chatHistoryElement) return;
    chatHistoryElement.innerHTML = '';
    const lang = i18n.detect();
    chatState.messages.forEach((msg) => {
      const messageDiv = document.createElement('div');
      const isUser = msg.role === 'user';
      messageDiv.className = `p-4 rounded-lg max-w-[90%] sm:max-w-[80%] ${isUser ? 'ml-auto bg-cosmic-gold/10 border border-cosmic-gold/20' : 'mr-auto bg-cosmic-void border border-cosmic-border'}`;
      
      const roleLabel = isUser 
        ? (lang === 'fr' ? 'Vous' : 'You')
        : 'Oracle';

      messageDiv.innerHTML = `
        <strong class="block text-xs uppercase tracking-wider mb-2 font-display ${isUser ? 'text-cosmic-gold' : 'text-cosmic-text-dim'}">${roleLabel}</strong>
        <p class="text-cosmic-text leading-relaxed whitespace-pre-wrap">${msg.content}</p>
      `;
      chatHistoryElement.appendChild(messageDiv);
    });
    chatHistoryElement.scrollTop = chatHistoryElement.scrollHeight;
  };

  const handleSendMessage = async () => {
    if (!userInputElement || !sendButtonElement) return;
    const userMessage = userInputElement.value.trim();
    if (!userMessage || chatState.isLoading) return;

    // 1. Update UI for user message
    chatState.messages.push({ role: 'user', content: userMessage });
    userInputElement.value = '';
    updateUI();

    chatState.isLoading = true;
    userInputElement.disabled = true;
    sendButtonElement.disabled = true;

    try {
      // 2. Check if we are in the follow-up phase (i.e. we have an analysis ID)
      if (!chatState.currentAnalysisId) {
        console.log('[Flow] Initiating initial analysis...');
        const newAnalysisId = 'rom'; // Using 'rom' mock key from database.ts / rag.ts
        chatState.currentAnalysisId = newAnalysisId;
      }

      // 3. Retrieve context from sessionStorage
      const lectureContext = sessionStorage.getItem('last_lecture_output') || "Aucune lecture disponible.";
      const currentLang = i18n.detect();
      
      const lightPrompt = `
        Agis comme un Oracle Karmique sage et profond.
        L'utilisateur va te poser une question ou te soumettre une réflexion basée sur sa lecture astrologique (contexte ci-dessous).
        Ne te contente pas de répéter le contexte. Développe, offre une perspective spirituelle, explique le sens caché des planètes impliquées, et guide l'utilisateur avec bienveillance.
        Réponds obligatoirement dans la langue de l'utilisateur qui est : ${currentLang}.
        
        --- CONTEXTE DE LA LECTURE ---
        ${lectureContext}
        --- FIN DU CONTEXTE ---
        
        Message de l'utilisateur: ${userMessage}
        
        Réponse de l'Oracle:
      `;

      // 4. Call native Gemma plugin or fallback
      let response = '';

      // Check if local AI is selected and available
      let useLocalConfig = false;
      const storedSettings = localStorage.getItem('karmic_ai_settings');
      if (storedSettings) {
        try {
          useLocalConfig = JSON.parse(storedSettings).useLocal === true;
        } catch (e) {}
      }

      let isLocalAvailable = false;
      if (capacitorBridge.isNative() && useLocalConfig) {
        try {
          const avail = await capacitorBridge.gemma.checkAvailability();
          if (avail && avail.available) {
            isLocalAvailable = true;
          }
        } catch (e) {}
      }

      if (isLocalAvailable) {
        console.log('[Chat] Using Native Gemma Synthesis...');
        await capacitorBridge.gemma.prepareModel(false);
        const nativeRes = await capacitorBridge.gemma.generate(
          "Tu es un Oracle Karmique sage, mystique et bienveillant. Fournis des réponses profondes et spirituelles.",
          lightPrompt,
          "synthesis",
          currentLang
        );
        response = nativeRes || "Oracle local indisponible.";
      } else {
        // Roue de secours : Si non-natif ou si le modèle local n'est pas dispo, on utilise le fallback
        // Pour les testeurs beta sans le modèle téléchargé, on effectue un appel API Cloud pour le chat !
        try {
          // Utilisation du endpoint de chat du backend API Cloud comme secours
          const chatResult = await api.chat(chatState.currentAnalysisId || 'rom', userMessage);
          if (chatResult && chatResult.ok && chatResult.reply) {
            response = chatResult.reply;
          } else {
            response = await GemmaWebFallback.generate(lightPrompt);
          }
        } catch (e) {
          response = await GemmaWebFallback.generate(lightPrompt);
        }
      }

      // 5. Update UI with assistant response
      chatState.messages.push({ role: 'assistant', content: response });

    } catch (error) {
      console.error('Error during message handling:', error);
      chatState.messages.push({ role: 'assistant', content: 'Error: Could not process request. Please try again.' });
    } finally {
      chatState.isLoading = false;
      userInputElement.disabled = false;
      sendButtonElement.disabled = false;
      updateUI();
      userInputElement.focus();
    }
  };

  // --- Event Listeners ---
  if (sendButtonElement) {
    sendButtonElement.addEventListener('click', handleSendMessage);
  }
  if (userInputElement) {
    userInputElement.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        handleSendMessage();
      }
    });
  }

  // --- Initial Render ---
  updateUI();

  // Expose to global window so it can be called from outside
  (window as any).openChatWithQuote = (quote: string) => {
    if (userInputElement) {
      const explainPrefix = i18n.detect() === 'fr' 
        ? 'Peux-tu m\'expliquer ce que tu entends par : '
        : 'Can you explain what you mean by: ';
      userInputElement.value = `${explainPrefix}"${quote}" ? `;
      userInputElement.focus();
    }
  };
</script>
