---
// src/components/HeroSection.astro
// Phase 1.3 — Full-screen cosmic hero with gold/dark palette (no purple, no pink)
// Imported by: pages/index.astro
// Scroll CTA targets #login for downstream login card
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-cosmic-bg"
  aria-label="Hero Karmic Gochara"
>
  <!-- ===== Cosmic glow orbs ===== -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <div
      class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full"
      style="background: radial-gradient(circle, rgba(201,168,76,0.06) 0%, transparent 70%)"
    ></div>
    <div
      class="absolute bottom-8 right-8 w-[400px] h-[400px] rounded-full"
      style="background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 60%)"
    ></div>
    <div
      class="absolute top-1/3 left-[10%] w-[250px] h-[250px] rounded-full"
      style="background: radial-gradient(circle, rgba(138,106,48,0.07) 0%, transparent 60%)"
    ></div>
  </div>

  <!-- ===== Content ===== -->
  <div class="relative z-10 w-full max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Star glyph -->
    <div class="mb-6 sm:mb-8 animate-fade-up stagger-1">
      <span class="text-5xl sm:text-6xl inline-block text-cosmic-gold/60">✦</span>
    </div>

    <!-- Title: KARMIC GOCHARA -->
    <h1
      class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-display font-bold
             tracking-[0.12em] sm:tracking-[0.15em] leading-none mb-6 sm:mb-8
             bg-gradient-to-r from-cosmic-gold via-yellow-200/90 to-cosmic-gold-dim
             bg-clip-text text-transparent
             animate-fade-up stagger-2"
    >
      KARMIC<br class="sm:hidden" /> GOCHARA
    </h1>

    <!-- Subtitle -->
    <p
      class="text-xl sm:text-2xl md:text-3xl font-body
             text-cosmic-gold/60 tracking-[0.12em] sm:tracking-[0.15em] mb-4
             animate-fade-up stagger-3"
    >
      L'alchimie des cycles cosmiques
    </p>

    <!-- Teaser -->
    <p
      class="text-base sm:text-lg text-cosmic-text-dim max-w-xl mx-auto leading-relaxed mb-10 sm:mb-14
             animate-fade-up stagger-4"
    >
      Explore les influences astrologiques qui façonnent ta destinée.<br class="hidden sm:inline" />
      Aligne-toi avec le flux universel.
    </p>

    <!-- CTA Button — scrolls to login section -->
    <div class="animate-fade-up stagger-5">
      <a
        href="#login"
        class="group inline-flex items-center gap-3 px-8 sm:px-10 py-3 sm:py-4
               text-base sm:text-lg font-display font-semibold tracking-wider
               rounded-full border border-cosmic-gold/50 text-cosmic-gold
               transition-all duration-500 ease-out
               hover:bg-cosmic-gold hover:text-cosmic-bg hover:border-cosmic-gold
               hover:shadow-[0_0_30px_rgba(201,168,76,0.3)]
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-cosmic-gold/60 focus-visible:ring-offset-2
               focus-visible:ring-offset-cosmic-bg"
      >
        S'identifier
        <svg
          class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-500 ease-out
                 group-hover:translate-y-0.5"
          fill="none" stroke="currentColor" viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </div>

  <!-- ===== Scroll-down indicator ===== -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in stagger-5">
    <div class="flex flex-col items-center gap-2" aria-hidden="true">
      <span
        class="block w-px h-8 rounded-full opacity-50 hero-scroll-bounce"
        style="background: linear-gradient(to bottom, rgba(201,168,76,0.8), transparent)"
      ></span>
    </div>
  </div>
</section>

<style>
  @keyframes hero-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.7; }
    30%            { transform: translateY(6px); opacity: 0.2; }
  }
  .hero-scroll-bounce {
    animation: hero-bounce 2.4s ease-in-out infinite;
  }
</style>
