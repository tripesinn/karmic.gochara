---
// src/components/DailyReading.astro

// 1. COMPONENT SCRIPT (Frontmatter)
// This runs at build time and fetches data from the local API endpoint.
// We use a relative path to the API endpoint within the Astro project structure.
import type { AstroProps } from 'astro/types';

// Définition des types des props si nécessaire
interface Props {} 
const { title = "Doctrine Quotidienne" } = Astro.props;

// Appel à notre API Astro locale. C'est la clé de la migration !
const response = await fetch('/api/doctrine');
const doctrineData = await response.json();
---

<!-- 2. COMPONENT TEMPLATE -->
<div class="daily-reading-card bg-gray-900 p-8 rounded-xl shadow-2xl max-w-3xl mx-auto mt-12">
  <header class="mb-6 border-b border-gold pb-4">
    <h2 class="text-4xl font-bold text-gold">{doctrineData.title}</h2>
    <p class="text-gray-400 text-lg mt-1">Publié le {doctrineData.date}</p>
  </header>
  
  <div class="space-y-6">
    <!-- Texte principal de la lecture -->
    <div class="bg-gray-800 p-6 rounded-lg">
      <p class="text-xl text-white leading-relaxed italic">{doctrineData.text}</p>
    </div>

    <!-- Carte de focalisation et recommandation -->
    <div class="grid grid-cols-2 gap-4">
      <div class="p-4 rounded-lg bg-purple-900/30 border border-purple-700">
        <h3 class="text-lg font-semibold text-purple-300">Focus Actuel</h3>
        <p class="text-white">{doctrineData.focus_area}</p>
      </div>
      <div class="p-4 rounded-lg bg-gold-900/30 border border-gold-700">
        <h3 class="text-lg font-semibold text-gold">Recommandation</h3>
        <p class="text-white">{doctrineData.recommendation}</p>
      </div>
    </div>
  </div>

  <!-- Indicateur de résonance -->
  <div class="mt-8 pt-4 border-t border-gray-700 flex justify-between items-center">
    <span class="text-gray-400">Résonance Karmique:</span>
    <span class="text-gold font-bold text-2xl">
      {doctrineData.isKarmic ? '⚡ Active' : '🧘 Calme'}
    </span>
  </div>
</div>