{
  "appId": "com.karmicgochara.app",
  "appName": "Karmic GoChara",
  "webDir": "www",
  "server": {
    "cleartext": true
  },
  "plugins": {
    "KarmicGoogleAuth": {
      "serverClientId": "732214018947-ee5v5hi70fer05edbti3hjig22knngb8.apps.googleusercontent.com"
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "732214018947-ee5v5hi70fer05edbti3hjig22knngb8.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a08",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0a08"
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a0a08",
    "buildOptions": {
      "compileOptions": {
        "sourceCompatibility": "VERSION_17",
        "targetCompatibility": "VERSION_17"
      }
    }
  },
  "ios": {
    "backgroundColor": "#0a0a08"
  }
}
